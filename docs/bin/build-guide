#!/usr/bin/env ruby
# frozen_string_literal: true

# Renders the CafeCar reference guide onto the Jekyll docs site from its SINGLE
# SOURCE: skills/cafe_car/references/*.md (the agent-skill reference pages, also
# read by GitMCP). We do NOT keep a second copy of the prose in docs/ — this
# script wraps each source file in Jekyll front matter at build time and writes
# it into docs/guide/, which is git-ignored (never committed). Edit the source
# under skills/cafe_car/references/; this script regenerates the site pages.
#
# GitHub Pages builds Jekyll in safe mode: symlinks aren't followed and custom
# plugins are disabled, so neither a symlink nor a _plugins generator can reach
# files outside docs/. Running this as a build step (see .github/workflows/pages.yml)
# is the single-source path that survives the safe-mode build.
#
# Usage: ruby docs/bin/build-guide  (run from the repo root)

require "fileutils"

ROOT   = File.expand_path("../../..", __FILE__)
SOURCE = File.join(ROOT, "skills/cafe_car/references")
OUTPUT = File.join(ROOT, "docs/guide")

# Reading order for the guide index (source basenames without .md). Anything not
# listed still renders but sorts after these, alphabetically.
ORDER = %w[
  controllers views policies presenters forms
  filtering navigation components locales turbo
].freeze

def order_of(name) = (ORDER.index(name) || ORDER.size + name.ord).to_s.rjust(3, "0")

def title_of(body)
  body[/^\#\s+(.+)$/, 1]&.strip || "Guide"
end

# Same-directory cross-links in the source are `](name.md)` / `](name.md#anchor)`.
# Jekyll renders each page as name.html, so rewrite the extension to keep them live.
def relink(body) = body.gsub(/\]\(([a-z_]+)\.md/, '](\1.html')

FileUtils.rm_rf(OUTPUT)
FileUtils.mkdir_p(OUTPUT)

sources = Dir[File.join(SOURCE, "*.md")].sort
abort "no reference sources under #{SOURCE}" if sources.empty?

sources.each do |path|
  name = File.basename(path, ".md")
  body = File.read(path)

  front = <<~YAML
    ---
    layout: default
    title: #{title_of(body).inspect}
    guide_order: #{order_of(name).inspect}
    ---
    <!-- Generated from skills/cafe_car/references/#{name}.md — the single source.
         Edit that file, not this one. Regenerated by docs/bin/build-guide. -->
  YAML

  File.write(File.join(OUTPUT, "#{name}.md"), front + relink(body))
end

puts "built #{sources.size} guide page(s) into docs/guide/ from #{SOURCE}"

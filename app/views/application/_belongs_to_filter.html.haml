-# Set membership on the foreign key (`?author_id[]=3&author_id[]=5`) through the
-# same Tom Select typeahead the edit form uses — multi-select filters by any of
-# the chosen records (a `WHERE author_id IN (…)` set).
= Field do
  = f.label info.input_key
  = f.association info.method, multiple: true, selected: f.object.value(info.input_key)

= form_with url: "", method: :get, class: "search" do |f|
  - filter_params.each do |key, value|
    = hidden_field_tag key, value
  = hidden_field_tag :sort, params[:sort] if params[:sort].present?
  - label = t(:search, scope: :helpers, default: "Search")
  = Group do
    = f.search_field :q, value: search_term, placeholder: label
    = f.button label, name: nil, class: ui.Button.class_name

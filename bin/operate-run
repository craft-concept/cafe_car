#!/usr/bin/env bash
#
# operate-run — launch this venture's Claude operator session.
#
# The single canonical launcher for the operator. BOTH `bin/operate run` (manual,
# from the repo) and holdco's `bin/holdco run <id>` (which wraps this in a named
# tmux window via lib/tasks/ventures.rake) use THIS script to construct and exec
# the `claude` invocation: persona, model, effort, remote-control, email channel,
# and the /loop standing-work prompt. It replaces the old bespoke root launchers
# (./bindery, ./conductor, ./cbloom, ./homelab, ./trader).
#
# holdco resolves the venture's settings from the registry and passes them via env
# (OP_MODEL, OP_EFFORT, OP_MODE, OP_WORK, OP_REMOTE_NAME, EMAIL_CHANNEL_ADDR). Run
# standalone, it falls back to operate.json `run.*` then built-in defaults, so a
# venture repo launches with no holdco repo on the box.
#
#   bin/operate run                 /loop standing-work session (mode-aware)
#   bin/operate run "<prompt>"      one-off opening prompt (no /loop driver)
#   DRY_RUN=1 bin/operate run       print the claude argv instead of exec'ing
#
# Settings — env (holdco/owner override) falls back to operate.json run.* then default:
#   OP_MODEL      / run.model     model alias           (default: opus)
#   OP_EFFORT     / run.effort    reasoning effort      (default: high)
#   OP_MODE       / run.mode      loop cadence: long-loop | cold | cron (default: long-loop)
#   OP_WORK                       standing-work text    (default: "Continue <name> operation.")
#   OP_REMOTE_NAME / run.title    --remote-control conversation name
#   run.channels                  --channels value      (default: plugin:email@holdco-fleet)
#   OP_REMOTE=0                   disable --remote-control
#   OP_RESUME=1                   --continue (resume last session)
#   COLD_FALLBACK_EVERY           cold-mode /loop interval (default: 8h)
set -uo pipefail

DIR="$(cd "$(dirname "$0")" && pwd)"
REPO="$(cd "$DIR/.." && pwd)"
JQ="$(command -v jq 2>/dev/null || true)"
CONFIG="${OPERATE_CONFIG:-$REPO/operate.json}"
cfg() { [ -n "$JQ" ] && [ -f "$CONFIG" ] && "$JQ" -r ".$1 // empty" "$CONFIG" 2>/dev/null || true; }

cd "$REPO"

PERSONA="$REPO/.claude/agents/operator.md"
[ -f "$PERSONA" ] || { echo "operate-run: missing persona $PERSONA" >&2; exit 1; }

venture="$(cfg venture)"
name="$(cfg run.title)"; name="${name:-${venture:-this venture}}"

model="${OP_MODEL:-$(cfg run.model)}";     model="${model:-opus}"
effort="${OP_EFFORT:-$(cfg run.effort)}";  effort="${effort:-high}"
mode="${OP_MODE:-$(cfg run.mode)}";        mode="${mode:-long-loop}"
channels="$(cfg run.channels)";            channels="${channels:-plugin:email@holdco-fleet}"
remote_name="${OP_REMOTE_NAME:-$name Operator}"
work="${OP_WORK:-Continue $name operation.}"

# Assemble the claude invocation. Kept byte-identical to the pre-rename
# ventures:run path (persona, model, effort, --dangerously-skip-permissions,
# email channel, --remote-control, /loop prompt) — this is a relocation.
args=()
[ "${OP_REMOTE:-1}" != 0 ] && args+=( --remote-control "$remote_name" )
args+=( --model "$model" --effort "$effort" --dangerously-skip-permissions
        --channels "$channels" --append-system-prompt-file "$PERSONA" )
[ "${OP_RESUME:-0}" = 1 ] && args+=( --continue )

# Opening prompt: explicit args win (a one-off prompt, no standing driver — e.g.
# trading's cron-arm launch). Otherwise the /loop standing-work prompt; `cold`
# mode caps the loop at a long fallback interval, everything else self-paces.
if [ "$#" -gt 0 ]; then
	args+=( "$@" )
elif [ "$mode" = cold ]; then
	args+=( "/loop ${COLD_FALLBACK_EVERY:-8h} $work" )
else
	args+=( "/loop $work" )
fi

if [ "${DRY_RUN:-0}" = 1 ] || [ "${HOLDCO_DEBUG:-0}" = 1 ]; then
	printf 'claude'
	for a in "${args[@]}"; do printf ' %q' "$a"; done
	printf '\n'
	exit 0
fi

exec claude "${args[@]}"

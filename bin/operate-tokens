#!/usr/bin/env bash
#
# operate-tokens — fleet pacing signal + token/usage view.
#
# Reads the per-session caches written by ~/bin/claude-status (dotfiles; one
# file per venture/holdco under ~/.cache/claude-usage/usage.*) and prints:
#   * the current 7-day/5-hour plan-cap % + its reset — the "are we approaching
#     the cap" signal. rate_limits is ACCOUNT-WIDE, so the authoritative value
#     is the FRESHEST reading in the CURRENT window: newest reset epoch first
#     (a past-window reading can never surface; expired windows are skipped
#     outright), then newest UPDATED_AT within it. NOT the max: the provider's
#     used_percentage is NOT monotonic within a window — it can be revised DOWN
#     with the same reset epoch (2026-07-01 incident: the endpoint dropped
#     45% → 14% mid-window while a max/latch pinned the fleet at 45% and
#     over-throttled pacing for days). The latest provider sample is the truth;
#   * the per-session breakdown (model, context %, 5h/7d %, age);
#   * a directional daily $ spend via ccusage (npx/installed), cached so the
#     tmux path never blocks on the network.
#
# Modes:
#   operate tokens          readable table (default)
#   operate tokens --tmux    one-liner for the status bar
#   operate tokens --pace    one machine-readable line for loops/schedulers:
#                            "<sleep_seconds> <SIGNAL> left=<n> used=<n> alloc=<n> cap=<n>
#                             [MONDAY-BURN …] codex=<SIG> [claude_forced=<SIG>] ADVICE: <text>"
#                            SIGNAL (field 2) is the CLAUDE signal — the operator's own
#                            pace. `cap=` is the 7-day HARD-CAP % used (0..100) — distinct
#                            from the allowance-relative used=/alloc=/left=. The email
#                            channel reads cap= for its >95%-only hold gate (deliver
#                            mail unless the fleet is over 95% of the 7-day cap).
#                            The 6-field prefix through cap= is byte-stable; codex=/
#                            ADVICE: are ADDITIVE trailing tokens (like MONDAY-BURN).
#                            The signal folds in this venture's registry status when
#                            tokens.registry_file (operate.json) is configured AND
#                            present: a `hold` status pins YELLOW with the long
#                            sleep — the owner-directed holding pattern. Absent /
#                            missing file → the fleet signal passes through (fail open).
#   operate tokens --set-signal <claude|codex>=<GREEN|YELLOW|RED> [--until <dur|iso>]
#                            owner lever: force a provider's signal fleet-wide (one shared
#                            file). --until takes a duration (2h/30m/3d) or a date -d string;
#                            omitted = until cleared. claude forces the operator pace;
#                            codex is advice-only (codex has NO computed signal — pure lever).
#   operate tokens --clear-signal [claude|codex]
#                            clear one provider's forced signal (or the whole file if omitted).
#   operate tokens --watch [secs]
#                            owner monitor: live-refreshing table (default 60s)
#
# Owner-monitor design (the whole thing, kept lean on purpose): this script IS
# the single source of truth — --watch just re-renders the table on a loop in
# the terminal. The table already carries everything the owner needs: 7-day %
# used + linear projection, the cumulative allowance/remaining, the dream
# budget, the signal, $ spend today and the last 7 days (ccusage, claude +
# codex, API-list-rate estimate), and the per-session breakdown. No new
# service, page, or deploy.
#
# Config (operate.json, all optional; env seams win for tests): tokens.usage_dir,
# tokens.registry_file, tokens.tz, tokens.day_budget_pct, tokens.night_budget_pct,
# tokens.green_sleep_s, tokens.busy_sleep_s, tokens.red_at_pct, and tokens.codex.*
# (codex/ChatGPT weekly usage + grant pacing — sessions_dir, weekly_reset, used_pct,
# grants[]). Built-in defaults match today's behavior, so a bare copy runs unchanged.
#
# Two INDEPENDENT provider signals (owner refinement 2026-07-15), both in
# GREEN/YELLOW/RED, told apart by a `claude:`/`codex:` label:
#   * claude — the computed pace altimeter (below), overridable by the lever;
#   * codex  — a PURE owner lever (--set-signal codex=…), NO budget computation;
#              default `unset`. Advice-only — codex is a tool, not the loop's budget.
# ADVICE (fused from the pair) rides the --pace tail + a table/tmux line so the
# operator sees both providers + which-engine guidance every pass.
# The codex weekly-usage SCAN (~/.codex/sessions rate-limit snapshots; env seam
# CODEX_SESSIONS_DIR wins for tests) is KEPT as table-mode INFORMATIONAL display
# only (the 07-14 SPEND/ON-GLIDE/SPENT altimeter is retired — the lever replaced
# it). auth.json/credentials are never read.
# The per-provider forced signals live in one shared file <usage_dir>/pace-override
# so every operator on the box reads the same lever (works with holdco absent).
#
# Deps: bash only (jq optional, used to read operate.json + ccusage JSON + the codex
# rollout line — a bash/sed fallback covers the no-jq case).
# Degrades to a usable view when ccusage / caches / jq are missing.

set -uo pipefail
export LC_ALL=C

JQ="$(command -v jq 2>/dev/null || true)"
CONFIG="${OPERATE_CONFIG:-$(cd "$(dirname "$0")/.." 2>/dev/null && pwd)/operate.json}"
cfg() { [ -n "$JQ" ] && [ -f "$CONFIG" ] && "$JQ" -r ".$1 // empty" "$CONFIG" 2>/dev/null || true; }
untilde() { case "$1" in "~/"*) printf '%s' "$HOME/${1#\~/}" ;; *) printf '%s' "$1" ;; esac; }

CACHE_DIR="${CLAUDE_USAGE_DIR:-}"
[ -n "$CACHE_DIR" ] || CACHE_DIR="$(untilde "$(cfg tokens.usage_dir)")"
[ -n "$CACHE_DIR" ] || CACHE_DIR="$HOME/.cache/claude-usage"
# One shared per-provider signal-override file (owner lever), read by every
# operator on the box. Lives beside the account-wide usage caches so it moves
# with the CLAUDE_USAGE_DIR test seam automatically.
OVERRIDE_FILE="$CACHE_DIR/pace-override"
CCUSAGE_CACHE="$CACHE_DIR/ccusage-daily"
CCUSAGE_TTL=600 # seconds; tmux reads this cache, table mode refreshes it
CACHE_TTL_SECONDS=300 # prompt-cache warm window (sliding, reset each turn)
MICH_TZ="$(cfg tokens.tz)"; [ -n "$MICH_TZ" ] || MICH_TZ=America/Detroit
# OPERATE_TOKENS_NOW is a test seam only (tests/tokens-pace-test.sh) — a fixed
# clock so the Michigan work-day / night arithmetic is deterministic.
now="${OPERATE_TOKENS_NOW:-$(date +%s)}"

MODE="table"
WATCH_IVAL=60
SET_SPEC="" CLEAR_PROV="all" UNTIL_RAW=""
while [ $# -gt 0 ]; do
	case "$1" in
	--tmux) MODE="tmux" ;;
	--pace) MODE="pace" ;;
	--set-signal) MODE="set-signal"; SET_SPEC="${2:-}"; shift ;;
	--clear-signal) MODE="clear-signal"; case "${2:-}" in claude | codex) CLEAR_PROV="$2"; shift ;; esac ;;
	--until) UNTIL_RAW="${2:-}"; shift ;;
	--watch)
		MODE="watch"
		case "${2:-}" in [0-9]*) WATCH_IVAL="$2"; shift ;; esac
		;;
	-h | --help) awk 'NR==1{next} /^#/{sub(/^# ?/,"");print;next}{exit}' "$0"; exit 0 ;;
	esac
	shift
done

# ---- owner signal override (per-provider lever) -----------------------------
# One account-wide budget => ONE shared file, so every operator reads the same
# lever. Per-provider entries (CLAUDE_*/CODEX_*); an empty/absent UNTIL = no
# expiry; an entry with UNTIL <= now is ignored (never rewritten on a read path,
# so concurrent operators don't race). The claude lever forces the operator's own
# pace signal; the codex lever is advice-only (codex has no computed signal).

# parse_until <dur-or-iso> -> epoch (empty on failure / empty input). A bare
# duration (12s/30m/2h/3d) is relative to `now`; anything else goes to `date -d`.
parse_until() {
	local raw="$1"; [ -n "$raw" ] || return
	if [[ "$raw" =~ ^([0-9]+)([smhd])$ ]]; then
		local n="${BASH_REMATCH[1]}" u="${BASH_REMATCH[2]}" mult=1
		case "$u" in s) mult=1 ;; m) mult=60 ;; h) mult=3600 ;; d) mult=86400 ;; esac
		printf '%s' $((now + n * mult)); return
	fi
	date -d "$raw" +%s 2>/dev/null || true
}

# ovget <KEY> — raw value of a line in the override file (no expiry filtering).
ovget() { sed -n "s/^$1=//p" "$OVERRIDE_FILE" 2>/dev/null | head -1; }

# ovwrite <CS> <CU> <XS> <XU> — rewrite the file from the four values, dropping a
# provider whose signal is empty; remove the file entirely when both are empty.
ovwrite() {
	if [ -z "$1" ] && [ -z "$3" ]; then rm -f "$OVERRIDE_FILE"; return; fi
	mkdir -p "$(dirname "$OVERRIDE_FILE")"
	{
		[ -n "$1" ] && printf 'CLAUDE_SIGNAL=%s\nCLAUDE_UNTIL=%s\n' "$1" "$2"
		[ -n "$3" ] && printf 'CODEX_SIGNAL=%s\nCODEX_UNTIL=%s\n' "$3" "$4"
	} >"$OVERRIDE_FILE"
}

if [ "$MODE" = "set-signal" ]; then
	prov="${SET_SPEC%%=*}"; sig="${SET_SPEC##*=}"
	case "$prov" in claude | codex) ;; *) echo "set-signal: provider must be claude or codex (got '$prov')" >&2; exit 2 ;; esac
	case "$sig" in GREEN | YELLOW | RED) ;; *) echo "set-signal: signal must be GREEN|YELLOW|RED (got '$sig')" >&2; exit 2 ;; esac
	until=""
	if [ -n "$UNTIL_RAW" ]; then
		until="$(parse_until "$UNTIL_RAW")"
		[ -n "$until" ] || { echo "set-signal: could not parse --until '$UNTIL_RAW'" >&2; exit 2; }
	fi
	CS="$(ovget CLAUDE_SIGNAL)" CU="$(ovget CLAUDE_UNTIL)" XS="$(ovget CODEX_SIGNAL)" XU="$(ovget CODEX_UNTIL)"
	case "$prov" in claude) CS="$sig" CU="$until" ;; codex) XS="$sig" XU="$until" ;; esac
	ovwrite "$CS" "$CU" "$XS" "$XU"
	umsg="no expiry (until cleared)"; [ -n "$until" ] && umsg="until $(date -d "@$until" '+%a %b %-d %H:%M %Z' 2>/dev/null)"
	printf 'signal override set: %s = %s (%s)\n' "$prov" "$sig" "$umsg"
	exit 0
fi

if [ "$MODE" = "clear-signal" ]; then
	if [ "$CLEAR_PROV" = "all" ]; then rm -f "$OVERRIDE_FILE"; echo "signal override cleared (all providers)"; exit 0; fi
	CS="$(ovget CLAUDE_SIGNAL)" CU="$(ovget CLAUDE_UNTIL)" XS="$(ovget CODEX_SIGNAL)" XU="$(ovget CODEX_UNTIL)"
	case "$CLEAR_PROV" in claude) CS="" CU="" ;; codex) XS="" XU="" ;; esac
	ovwrite "$CS" "$CU" "$XS" "$XU"
	echo "signal override cleared: $CLEAR_PROV"
	exit 0
fi

# Read the active levers for this pass: valid signal AND (no expiry OR future).
CLAUDE_FORCE="" CLAUDE_FORCE_UNTIL="" CODEX_LEVER="" CODEX_LEVER_UNTIL=""
if [ -f "$OVERRIDE_FILE" ]; then
	cs="$(ovget CLAUDE_SIGNAL)" cu="$(ovget CLAUDE_UNTIL)" xs="$(ovget CODEX_SIGNAL)" xu="$(ovget CODEX_UNTIL)"
	case "$cs" in GREEN | YELLOW | RED)
		if [ -z "$cu" ] || ! [[ "$cu" =~ ^[0-9]+$ ]] || ((cu > now)); then CLAUDE_FORCE="$cs" CLAUDE_FORCE_UNTIL="$cu"; fi ;;
	esac
	case "$xs" in GREEN | YELLOW | RED)
		if [ -z "$xu" ] || ! [[ "$xu" =~ ^[0-9]+$ ]] || ((xu > now)); then CODEX_LEVER="$xs" CODEX_LEVER_UNTIL="$xu"; fi ;;
	esac
fi

# --watch: the owner monitor — re-render the table every N seconds (default 60).
# Just a loop around the default mode; the table is the single source of truth.
if [ "$MODE" = "watch" ]; then
	while :; do
		printf '\033[2J\033[H'
		"$0"
		printf '\n%s · refreshes every %ss · Ctrl-C to quit\n' "$(date '+%a %-I:%M%P')" "$WATCH_IVAL"
		sleep "$WATCH_IVAL"
	done
fi

# ---- read caches ------------------------------------------------------------

# Round a possibly-float percentage to an integer; empty -> empty.
round() { [ -n "${1:-}" ] && printf '%.0f' "$1" 2>/dev/null || true; }

# Humanize seconds-until as "4d" / "5h" / "12m".
human_until() {
	local s="$1"
	((s < 0)) && s=0
	if ((s >= 86400)); then printf '%dd' $((s / 86400))
	elif ((s >= 3600)); then printf '%dh' $((s / 3600))
	else printf '%dm' $(((s + 59) / 60)); fi
}

shopt -s nullglob
files=("$CACHE_DIR"/usage.*)

# Live session CWDs — the set of dirs backed by a running claude/node process, so
# we can tell a live-but-idle operator from a corpse cache file. A cache whose CWD
# isn't here AND whose last update is >24h old is a dead session from an old reset
# window (e.g. a finished test session: chtest-cwd, t-chan, render); we still feed
# its reading into the account-wide cap MAX below (that's robust to it) but hide it
# from the per-session table so the fleet view isn't cluttered with corpses.
declare -A LIVE_CWD
DEAD_TTL=86400 # 24h — a session stale longer than this AND with no process is a corpse
for pcwd in /proc/[0-9]*/cwd; do
	link="$(readlink "$pcwd" 2>/dev/null)" || continue
	[ -n "$link" ] || continue
	pid="${pcwd#/proc/}"; pid="${pid%/cwd}"
	comm="$(cat "/proc/$pid/comm" 2>/dev/null)" || continue
	case "$comm" in claude | node) LIVE_CWD["$link"]=1 ;; esac
done

# Account-wide caps: track the FRESHEST reading in the CURRENT window — the
# latest reset epoch seen (expired windows skipped), tie-broken by UPDATED_AT.
# See the header: used_percentage is NOT monotonic within a window, so any
# max/high-water scheme turns a transient high into a week-long over-read.
cur_seven=-1 cur_seven_reset=-1 cur_seven_at=-1
cur_five=-1 cur_five_reset=-1 cur_five_at=-1
rows=() # label|model|ctx|five|seven|age_secs

for f in "${files[@]}"; do
	label="" model="" ctx="" five="" seven="" five_reset="" seven_reset="" updated="" tok="" cache="" sendcost="" lastturn="" cwd=""
	while IFS='=' read -r k v; do
		case "$k" in
		LABEL) label="$v" ;;
		CWD) cwd="$v" ;;
		MODEL) model="$v" ;;
		CTX_PCT) ctx="$v" ;;
		CTX_TOKENS) tok="$v" ;;
		CACHE_PCT) cache="$v" ;;
		SEND_COST) sendcost="$v" ;;
		LAST_TURN_TS) lastturn="$v" ;;
		FIVE_HOUR_PCT) five="$v" ;;
		FIVE_HOUR_RESET) five_reset="$v" ;;
		SEVEN_DAY_PCT) seven="$v" ;;
		SEVEN_DAY_RESET) seven_reset="$v" ;;
		UPDATED_AT) updated="$v" ;;
		esac
	done <"$f"
	[ -n "$label" ] || label="$(basename "$f" | sed 's/^usage\.//')"
	age=$((now - ${updated:-now}))
	# Show the row unless it's a corpse: no live process at its CWD AND stale >24h.
	# (Cap math below still sees every file — a corpse's reading is either from an
	# expired window (skipped) or older than a live session's (loses the freshness
	# race), so this pruning is display-only. ~/bin/claude-status also deletes such
	# corpses outright on its hourly prune pass.)
	if [ -n "${LIVE_CWD[$cwd]:-}" ] || ((age <= DEAD_TTL)); then
		rows+=("$label|$model|$ctx|$five|$seven|$age|$tok|$cache|$sendcost|$lastturn")
	fi

	# Account-wide caps: keep the FRESHEST reading in the latest open window (see
	# header). A newer reset epoch opens a fresh window; within the same window
	# the newest UPDATED_AT wins — never the max, the % can legitimately fall.
	# Expired windows (reset <= now) never surface.
	upd="${updated:-0}"; [[ "$upd" =~ ^[0-9]+$ ]] || upd=0
	if [ -n "$seven" ] && [[ "$seven_reset" =~ ^[0-9]+$ ]] && ((seven_reset > now)); then
		if ((seven_reset > cur_seven_reset)) \
			|| { ((seven_reset == cur_seven_reset)) && ((upd > cur_seven_at)); }; then
			cur_seven="$seven"; cur_seven_reset="$seven_reset"; cur_seven_at="$upd"
		fi
	fi
	if [ -n "$five" ] && [[ "$five_reset" =~ ^[0-9]+$ ]] && ((five_reset > now)); then
		if ((five_reset > cur_five_reset)) \
			|| { ((five_reset == cur_five_reset)) && ((upd > cur_five_at)); }; then
			cur_five="$five"; cur_five_reset="$five_reset"; cur_five_at="$upd"
		fi
	fi
done

# ---- fleet pacing — cumulative budget + traffic-light signals ----------------
# Plain cumulative-budget arithmetic (owner directive 2026-07-02, replacing the
# adaptive median-burn projection). ONE allowance accrues over the current 7-day
# window: 15% of the 7-day cap per Michigan work-day (Mon–Fri) elapsed, today
# INCLUDED (today's 15% is granted at its day start); plus 1% per night COMPLETED
# (each midnight crossed since the window opened, weekends included — tonight's 1%
# lands at the next midnight and funds the overnight dream cycle). Underspend just
# rolls forward. remaining = allowance − used(7-day %). Signals: RED iff used ≥ 90
# (the ONLY RED trigger); YELLOW iff remaining ≤ 0 OR it's a Michigan weekend;
# GREEN otherwise. Sleeps are fixed — GREEN 15m, YELLOW/RED 1h. Raw full week ≈
# 5×15 + 7×1 = 82%, but the allowance HARD-CAPS at ALLOC_CAP (80% — owner directive
# 2026-07-06; the band above is owner-reserved for assigned specials). All day/time
# logic uses Michigan time. See docs/COST.md.
# Budgets/sleeps/hard-cap are operate.json-overridable (tokens.*); defaults below.
DAY_BUDGET="$(cfg tokens.day_budget_pct)";   [ -n "$DAY_BUDGET" ]   || DAY_BUDGET=15    # % per Michigan work-day (incl. today)
NIGHT_BUDGET="$(cfg tokens.night_budget_pct)"; [ -n "$NIGHT_BUDGET" ] || NIGHT_BUDGET=1  # % per night completed (each midnight crossed)
GREEN_SLEEP="$(cfg tokens.green_sleep_s)";   [ -n "$GREEN_SLEEP" ]  || GREEN_SLEEP=900   # 15m — the GREEN cadence
BUSY_SLEEP="$(cfg tokens.busy_sleep_s)";     [ -n "$BUSY_SLEEP" ]   || BUSY_SLEEP=3600   # 1h  — both YELLOW and RED
HARD="$(cfg tokens.red_at_pct)";             [ -n "$HARD" ]         || HARD=90           # 7-day cap % that turns RED (the ONLY RED trigger)
ALLOC_CAP="$(cfg tokens.alloc_cap_pct)";     [ -n "$ALLOC_CAP" ]    || ALLOC_CAP=80     # allowance hard-caps here (owner directive 2026-07-06); band above is owner-reserved for assigned specials
SEVEN_WIN=604800 # 7-day window in seconds

pace_signal="GREEN"; pace_sleep="$GREEN_SLEEP"; pace_have=0; pace_mday=""; pace_dow=0
pace_used=0 pace_alloc=0 pace_left=0 pace_days=0 pace_nights=0 pace_capped=0
if [ -n "$cur_seven" ] && [ "$cur_seven" != "-1" ] && [[ "$cur_seven_reset" =~ ^[0-9]+$ ]]; then
	pace_have=1
	pace_dow="$(TZ="$MICH_TZ" date -d "@$now" +%u)" # 6=Sat 7=Sun
	pace_mday="$(TZ="$MICH_TZ" date -d "@$now" +%a)"
	# Window start = reset − 7d. Count Michigan calendar dates in [start, today]:
	# each Mon–Fri is a work-day (15%), and the day-span (midnights crossed) is the
	# nights completed (1% each). Both derive from the same date arithmetic.
	win_start=$((cur_seven_reset - SEVEN_WIN))
	start_date="$(TZ="$MICH_TZ" date -d "@$win_start" +%F)"
	today_date="$(TZ="$MICH_TZ" date -d "@$now" +%F)"
	pace_nights=$((($(date -d "$today_date" +%s) - $(date -d "$start_date" +%s)) / 86400))
	((pace_nights < 0)) && pace_nights=0
	for ((i = 0; i <= pace_nights; i++)); do
		[ "$(date -d "$start_date +$i days" +%u)" -le 5 ] && ((pace_days++))
	done
	pace_used="$(round "$cur_seven")"
	pace_alloc=$((DAY_BUDGET * pace_days + NIGHT_BUDGET * pace_nights))
	# Allowance hard-caps at ALLOC_CAP (owner directive 2026-07-06): the band above
	# is owner-reserved for special projects he assigns, not the fleet's to spend on
	# its own pacing. Clamp AFTER computing days/nights so the table can still show
	# the honest uncapped breakdown alongside a "capped" marker.
	if ((pace_alloc > ALLOC_CAP)); then pace_alloc=$ALLOC_CAP; pace_capped=1; fi
	pace_left=$((pace_alloc - pace_used))
	# Signal: RED at the hard cap; YELLOW when the cumulative allowance is spent or
	# it's the weekend; GREEN otherwise. Sleep is fixed per signal.
	if ((pace_used >= HARD)); then
		pace_signal="RED"; pace_sleep="$BUSY_SLEEP"
	elif ((pace_left <= 0)) || ((pace_dow >= 6)); then
		pace_signal="YELLOW"; pace_sleep="$BUSY_SLEEP"
	else
		pace_signal="GREEN"; pace_sleep="$GREEN_SLEEP"
	fi
fi

# ---- per-venture signal (this venture's registry status) ----------------------
# Resolve THIS venture's registry status from tokens.registry_file (operate.json,
# a ventures/<id>.md path) and adjust the FLEET signal for this one operator:
#   hold → owner-directed holding pattern: pins YELLOW with the long sleep,
#          regardless of budget — the operator executes owner instructions only.
# Per-venture *softening* (a launch venture getting a faster signal) belongs here
# too. No config / missing file / unknown status → the fleet signal passes through
# unchanged (fail open) — and on a holdco-less box the key is simply absent.
if [ "$MODE" = "pace" ]; then
	reg="$(untilde "$(cfg tokens.registry_file)")"
	if [ -n "$reg" ] && [ -f "$reg" ]; then
		vstatus="$(sed -n 's/^status:[[:space:]]*//p' "$reg" 2>/dev/null | head -n1)"
		case "$vstatus" in
		hold) pace_signal="YELLOW" pace_sleep="$BUSY_SLEEP" ;;
		esac
	fi
fi

# ---- owner levers: claude forces our own pace; codex is the advice signal -----
# The claude lever (if active) replaces the computed pace signal for ALL modes and
# wins over the hold pin — it's the owner's explicit hand on the wheel. The codex
# signal is PURELY the lever (no computation); `unset` until the owner sets it.
claude_forced=0 claude_computed_sig="$pace_signal"
if [ -n "$CLAUDE_FORCE" ]; then
	claude_forced=1
	pace_signal="$CLAUDE_FORCE"
	case "$CLAUDE_FORCE" in GREEN) pace_sleep="$GREEN_SLEEP" ;; *) pace_sleep="$BUSY_SLEEP" ;; esac
fi
codex_sig="${CODEX_LEVER:-unset}"

# Advice fuses the two provider signals into one which-engine sentence. No budget
# math — just claude signal × codex lever. Directional read, never a hard gate.
compute_advice() {
	local cs="$pace_signal" xs="$codex_sig"
	if [ "$pace_have" = 0 ] && [ "$claude_forced" = 0 ]; then
		echo "no Claude budget data yet — proceed conservatively"; return
	fi
	case "$cs" in
	GREEN)
		case "$xs" in
		GREEN) echo "both GREEN — spend freely; lean coding & research on codex/Sol" ;;
		YELLOW | RED) echo "Claude GREEN — spend freely on the loop; go easy on codex (codex $xs)" ;;
		*) echo "Claude GREEN — spend freely" ;;
		esac ;;
	YELLOW)
		case "$xs" in
		GREEN) echo "Claude YELLOW (allowance spent) — route coding & research to codex/Sol (codex GREEN)" ;;
		*) echo "Claude YELLOW — defer discretionary work, sleep long" ;;
		esac ;;
	RED)
		case "$xs" in
		GREEN) echo "Claude RED (near cap) — defer discretionary Claude work; push coding & research to codex/Sol (codex GREEN)" ;;
		*) echo "Claude RED — defer discretionary work to backlog, sleep long" ;;
		esac ;;
	*) echo "signal $cs — pace accordingly" ;;
	esac
}
pace_advice="$(compute_advice)"

# Monday burn-down hint (owner directive 2026-07-06): on a Michigan Monday, the
# fleet's duty is to spend the remaining 7-day window budget down to ~99% by the
# Tuesday 07:00 reset. Append a compact, machine-parseable hint AFTER alloc= while
# there is still window budget to burn (used < 99). Suppressed while claude is
# FORCED (a deliberate override would contradict a burn nudge). Field positions
# 1/2 and the left=/used=/alloc= fields are untouched.
pace_hint=""
if [ "$pace_have" = 1 ] && ((pace_dow == 1)) && ((pace_used < 99)) && [ "$claude_forced" = 0 ]; then
	pace_hint=" MONDAY-BURN target~99 by Tue 07:00"
fi

if [ "$MODE" = "pace" ]; then
	# cap= is the raw 7-day HARD-CAP % used (= pace_used; RED fires at cap >= HARD).
	# It is appended AFTER alloc= (before any Monday hint) so positional parsers of
	# the first fields are untouched; the email channel greps cap= for its >95% hold
	# gate. When there's no cap data (pace_have=0) cap=0 — the channel fails open
	# (delivers) rather than holding on an unknown budget.
	# ADDITIVE tail (after the byte-stable 6-field prefix): codex=<lever>, an optional
	# claude_forced=<SIG> marker, then a trailing human ADVICE: to end-of-line. No
	# consumer reads past cap= positionally, so fields 1-2 + left/used/alloc/cap stay
	# byte-identical whether or not a lever is set.
	codex_tail=" codex=$codex_sig"
	[ -n "$CODEX_LEVER" ] && [ -n "$CODEX_LEVER_UNTIL" ] && codex_tail+=" codex_until=$CODEX_LEVER_UNTIL"
	forced_tail=""
	if [ "$claude_forced" = 1 ]; then
		forced_tail=" claude_forced=$pace_signal"
		[ -n "$CLAUDE_FORCE_UNTIL" ] && forced_tail+=" claude_until=$CLAUDE_FORCE_UNTIL"
	fi
	printf '%s %s left=%s used=%s alloc=%s cap=%s%s%s%s ADVICE: %s\n' \
		"$pace_sleep" "$pace_signal" "$pace_left" "$pace_used" "$pace_alloc" "$pace_used" \
		"$pace_hint" "$codex_tail" "$forced_tail" "$pace_advice"
	exit 0
fi

# ---- ccusage daily $ (cached) ----------------------------------------------

# Echo today's fleet $ spend. In table mode, refresh the cache (may run npx,
# blocking briefly). In tmux mode, only read the cache — never block a redraw.
daily_cost() {
	local today; today="$(date +%F)"
	local fresh=0
	if [ -f "$CCUSAGE_CACHE" ]; then
		local cached_at; cached_at="$(sed -n 's/^AT=//p' "$CCUSAGE_CACHE")"
		[ -n "$cached_at" ] && ((now - cached_at < CCUSAGE_TTL)) && fresh=1
	fi

	if [ "$MODE" = "table" ] && [ "$fresh" = 0 ] && [ -n "$JQ" ]; then
		local bin="" json cost
		if command -v ccusage >/dev/null 2>&1; then bin="ccusage"
		elif command -v npx >/dev/null 2>&1; then bin="npx -y ccusage@latest"; fi
		if [ -n "$bin" ]; then
			json="$(timeout 90 $bin daily --json 2>/dev/null)"
			cost="$(printf '%s' "$json" | "$JQ" -r --arg d "$today" \
				'.daily[]? | select(.period==$d) | .totalCost' 2>/dev/null | head -1)"
			# Last 7 days (incl. today) as "YYYY-MM-DD:$int" pairs for the history line.
			days="$(printf '%s' "$json" | "$JQ" -r \
				'[.daily[-7:][]? | "\(.period):\(.totalCost|round)"] | join(" ")' 2>/dev/null)"
			if [ -n "$cost" ]; then
				mkdir -p "$CACHE_DIR"
				printf 'AT=%s\nDATE=%s\nCOST=%s\nDAYS=%s\n' "$now" "$today" "$cost" "$days" >"$CCUSAGE_CACHE"
			fi
		fi
	fi

	# Read whatever the cache holds (only trust it if it's for today).
	if [ -f "$CCUSAGE_CACHE" ]; then
		local d c; d="$(sed -n 's/^DATE=//p' "$CCUSAGE_CACHE")"; c="$(sed -n 's/^COST=//p' "$CCUSAGE_CACHE")"
		[ "$d" = "$today" ] && [ -n "$c" ] && printf '%.0f' "$c" 2>/dev/null && return
	fi
	return 1
}

# ---- render -----------------------------------------------------------------

seven_disp="$(round "$cur_seven")"; [ "$cur_seven" = "-1" ] && seven_disp=""
five_disp="$(round "$cur_five")"; [ "$cur_five" = "-1" ] && five_disp=""
reset_in=""
if [[ "$cur_seven_reset" =~ ^[0-9]+$ ]]; then reset_in="$(human_until $((cur_seven_reset - now)))"; fi
cost_today="$(daily_cost || true)"

# ---- codex (ChatGPT) weekly usage — INFORMATIONAL display only --------------
# Table/tmux ONLY (runs AFTER the --pace early-exit; --pace uses the lever, not
# this scan). Read-only scan of the rate-limit snapshot codex writes on every
# model turn into ~/.codex/sessions/YYYY/MM/DD/rollout-*.jsonl
# (payload.rate_limits.primary = {used_percent, resets_at} over a 7-day window).
# Freshest reading = the last rate_limits line in the newest session file that
# carries one. This drives NOTHING — the codex SIGNAL is the owner lever (codex_sig
# above), not computed from this usage (owner directive 2026-07-15). It's shown so
# the owner can eyeball consumption when deciding whether to flip the lever.
# auth.json / credentials are NEVER read; nothing is transmitted.
CODEX_DIR="${CODEX_SESSIONS_DIR:-}"
[ -n "$CODEX_DIR" ] || CODEX_DIR="$(untilde "$(cfg tokens.codex.sessions_dir)")"
[ -n "$CODEX_DIR" ] || CODEX_DIR="$HOME/.codex/sessions"

codex_used="" codex_reset="" codex_age=""
while IFS= read -r cf; do
	[ -n "$cf" ] || continue
	cline="$(grep 'rate_limits' "$cf" 2>/dev/null | tail -1)"
	[ -n "$cline" ] || continue
	if [ -n "$JQ" ]; then
		codex_used="$(printf '%s' "$cline" | "$JQ" -r '.payload.rate_limits.primary.used_percent // empty' 2>/dev/null)"
		codex_reset="$(printf '%s' "$cline" | "$JQ" -r '.payload.rate_limits.primary.resets_at // empty' 2>/dev/null)"
	fi
	# bash-only fallback (no jq, or jq missed): scope to the "primary":{...} block so
	# the always-0/absent "secondary" reading can never be picked up.
	if [ -z "$codex_used" ]; then
		cprim="$(printf '%s' "$cline" | grep -o '"primary":{[^}]*}')"
		codex_used="$(printf '%s' "$cprim" | sed -n 's/.*"used_percent":\([0-9.]*\).*/\1/p')"
		codex_reset="$(printf '%s' "$cprim" | sed -n 's/.*"resets_at":\([0-9]*\).*/\1/p')"
	fi
	if [ -n "$codex_used" ]; then
		codex_age=$((now - $(stat -c %Y "$cf" 2>/dev/null || echo "$now")))
		break
	fi
done < <(ls -t "$CODEX_DIR"/*/*/*/*.jsonl 2>/dev/null | head -50)

# Fall back to the manual config only when the scan found nothing (a box that hasn't
# run codex, or no jq/sed match). A config weekly_reset may be an ISO date -> epoch.
if [ -z "$codex_used" ]; then
	codex_used="$(cfg tokens.codex.used_pct)"
	codex_reset="$(cfg tokens.codex.weekly_reset)"
fi
if [ -n "$codex_reset" ] && ! [[ "$codex_reset" =~ ^[0-9]+$ ]]; then
	codex_reset="$(date -d "$codex_reset" +%s 2>/dev/null || true)"
fi

# Grants are MANUAL (not machine-readable): the soonest expiry strictly in the
# future is shown as informational context for the owner's lever decision.
codex_grant=""
while IFS= read -r g; do
	[ -n "$g" ] || continue
	ge="$(date -d "$g" +%s 2>/dev/null || true)"
	[ -n "$ge" ] || continue
	((ge <= now)) && continue
	if [ -z "$codex_grant" ] || ((ge < codex_grant)); then codex_grant="$ge"; fi
done < <(cfg 'tokens.codex.grants[].expires')

if [ "$MODE" = "tmux" ]; then
	# Compact: "Fleet 72%wk · resets 4d · $18 · claude:GREEN codex:GREEN". Color by
	# the claude signal when forced, else by the 7d threshold.
	if [ -z "$seven_disp" ] && [ "$claude_forced" = 0 ]; then
		# No cap data yet and no forced signal — show cost if we have it, else quiet.
		[ -n "$cost_today" ] && printf 'Fleet $%s today' "$cost_today"
		exit 0
	fi
	if [ "$claude_forced" = 1 ]; then
		case "$pace_signal" in RED) color="red" ;; YELLOW) color="yellow" ;; *) color="default" ;; esac
	else
		color="default"
		((seven_disp >= 90)) && color="red" || { ((seven_disp >= 70)) && color="yellow"; }
	fi
	out="Fleet"
	[ -n "$seven_disp" ] && out+=" ${seven_disp}%wk"
	[ -n "$reset_in" ] && out+=" · resets $reset_in"
	[ -n "$cost_today" ] && out+=" · \$$cost_today today"
	# Both provider signals (the per-pass read), with FORCED/lever markers.
	csuf=""; ((claude_forced)) && csuf="(F)"
	xsuf=""; [ -n "$CODEX_LEVER" ] && xsuf="(lever)"
	out+=" · claude:${pace_signal}${csuf} codex:${codex_sig}${xsuf}"
	[ -n "$codex_used" ] && out+=" · Codex $(round "$codex_used")% used"
	printf '#[fg=%s]%s#[default]' "$color" "$out"
	exit 0
fi

# --- table mode ---
bold=""; dim=""; rst=""; grn=""; ylw=""; redc=""
if [ -t 1 ]; then bold=$'\e[1m'; dim=$'\e[2m'; rst=$'\e[0m'; grn=$'\e[32m'; ylw=$'\e[33m'; redc=$'\e[31m'; fi

# Projection for one cap. Args: <label> <used%> <reset_epoch> <window_secs>
# [signal].
# Shows "% used · % elapsed · proj <p>% by reset (resets-in)". The projection is
# a plain linear extrapolation of used% over how far through the window we are
# (used/elapsed). The single verdict is the fleet SIGNAL (GREEN/YELLOW/RED,
# colored to match), shown only when a signal is passed (the 7-day cap). Degrades
# to bare used% if the reset epoch is missing/stale; shows "warming up" instead
# of a wild projection just after a reset.
pace_line() {
	local lbl="$1" reset="$3" win="$4" signal="${5:-}" u
	u="$(round "$2")"
	# Color for the optional fleet signal — the words are their own colors.
	local gtag=""
	if [ -n "$signal" ]; then
		local gc=""
		case "$signal" in GREEN) gc="$grn" ;; YELLOW) gc="$ylw" ;; RED) gc="$redc" ;; esac
		gtag="   $gc$signal$rst"
	fi
	if ! [[ "$reset" =~ ^[0-9]+$ ]] || [ -z "$u" ]; then
		printf '  %-11s %s%% used %s(no reset data — pace unknown)%s%s\n' "$lbl" "${u:-?}" "$dim" "$rst" "$gtag"
		return
	fi
	local remain=$((reset - now)); ((remain < 0)) && remain=0
	local resin; resin="$(human_until "$remain")"
	# Float math in awk: emit "elapsed%|projection%" (projection=warming when
	# barely into the window, so it isn't an explosive divide-by-~0).
	local out ep rest
	out="$(awk -v u="$u" -v r="$remain" -v w="$win" 'BEGIN{
		frac = 1 - r/w
		if (frac < 0) frac = 0; if (frac > 1) frac = 1
		ep = int(frac*100 + 0.5)
		if (frac < 0.05) { print ep "|warming"; exit }
		p = u/frac; if (p > 999) p = 999
		print ep "|" int(p+0.5)
	}')"
	IFS='|' read -r ep rest <<<"$out"
	if [ "$rest" = "warming" ]; then
		printf '  %-11s %s%% used · %s%% elapsed · %sproj — (warming up)%s (%s)%s\n' \
			"$lbl" "$u" "$ep" "$dim" "$rst" "$resin" "$gtag"
		return
	fi
	local projstr="$rest%"; [ "$rest" = "999" ] && projstr="999%+"
	printf '  %-11s %s%% used · %s%% elapsed · proj %s by reset (%s)%s\n' \
		"$lbl" "$u" "$ep" "$projstr" "$resin" "$gtag"
}

# Codex (ChatGPT Pro) block (table mode). The header shows the SIGNAL — which is
# the owner LEVER (codex_sig), not computed — with a forced/expiry marker. Weekly
# usage + grant are read-only INFORMATIONAL context (drive nothing; they just help
# the owner decide when to flip the lever). Degrades to a quiet line with no scan.
codex_line() {
	local sc lu="" lv="$codex_sig"
	case "$lv" in GREEN) sc="$grn" ;; YELLOW) sc="$ylw" ;; RED) sc="$redc" ;; *) sc="$dim" ;; esac
	if [ -n "$CODEX_LEVER" ]; then
		if [ -n "$CODEX_LEVER_UNTIL" ]; then
			lu=" ${dim}(owner lever, until $(date -d "@$CODEX_LEVER_UNTIL" '+%a %b %-d %H:%M' 2>/dev/null))${rst}"
		else lu=" ${dim}(owner lever)${rst}"; fi
	else lu=" ${dim}(no lever set — advice treats codex as neutral)${rst}"; fi
	printf '%s%s (ChatGPT Pro)%s   signal %s%s%s%s\n' "$bold" "Codex" "$rst" "$sc" "$lv" "$rst" "$lu"
	if [ -z "$codex_used" ]; then
		printf '  %s%-11s no usage reading (informational only; signal is the lever above)%s\n' "$dim" "Weekly:" "$rst"
		return
	fi
	local cu wk
	cu="$(round "$codex_used")"
	wk="${cu}% used"
	if [[ "$codex_reset" =~ ^[0-9]+$ ]]; then
		wk+=" · resets in $(human_until $((codex_reset - now))) ($(date -d "@$codex_reset" '+%a %b %-d' 2>/dev/null))"
	fi
	if [ -n "$codex_age" ]; then wk+=" · ${dim}$(human_until "$codex_age") ago${rst}"
	else wk+=" · ${dim}(config)${rst}"; fi
	printf '  %-11s %s %s(informational)%s\n' "Weekly:" "$wk" "$dim" "$rst"
	if [ -n "$codex_grant" ]; then
		printf '  %-11s soonest grant expires %s (%s) %s(informational)%s\n' \
			"Grant:" "$(date -d "@$codex_grant" '+%b %-d' 2>/dev/null)" "$(human_until $((codex_grant - now)))" "$dim" "$rst"
	fi
}

# signals_line — both provider signals side by side + FORCED/lever markers, then
# the fused advice. The operator's per-pass human read (the table analogue of the
# --pace codex=/ADVICE tail).
signals_line() {
	local cc xc cmk="" xmk=""
	case "$pace_signal" in GREEN) cc="$grn" ;; YELLOW) cc="$ylw" ;; RED) cc="$redc" ;; *) cc="$dim" ;; esac
	case "$codex_sig" in GREEN) xc="$grn" ;; YELLOW) xc="$ylw" ;; RED) xc="$redc" ;; *) xc="$dim" ;; esac
	if [ "$claude_forced" = 1 ]; then
		cmk=" ${bold}${redc}FORCED${rst}"
		[ -n "$CLAUDE_FORCE_UNTIL" ] && cmk+="${dim} until $(date -d "@$CLAUDE_FORCE_UNTIL" '+%b %-d %H:%M' 2>/dev/null)${rst}"
		cmk+=" ${dim}(computed ${claude_computed_sig})${rst}"
	fi
	if [ -n "$CODEX_LEVER" ]; then
		xmk=" ${dim}(lever"; [ -n "$CODEX_LEVER_UNTIL" ] && xmk+=" until $(date -d "@$CODEX_LEVER_UNTIL" '+%b %-d %H:%M' 2>/dev/null)"; xmk+=")${rst}"
	fi
	printf '  %-11s claude %s%s%s%s %s·%s codex %s%s%s%s\n' \
		"Signals:" "$cc" "$pace_signal" "$rst" "$cmk" "$dim" "$rst" "$xc" "$codex_sig" "$rst" "$xmk"
	printf '  %-11s %s\n' "Advice:" "$pace_advice"
}

echo "${bold}Fleet token usage${rst}"
if [ -n "$seven_disp" ]; then
	pace_line "7-day cap:" "$cur_seven" "$cur_seven_reset" 604800 "$pace_signal"
else
	echo "  ${dim}7-day plan cap: no data yet — sessions report it after their first API call${rst}"
fi
[ -n "$five_disp" ] && pace_line "5-hour cap:" "$cur_five" "$cur_five_reset" 18000
if [ "$pace_have" = 1 ]; then
	# Fleet pacing: cumulative allowance (work-days × 15% + nights × 1%) vs used,
	# the remaining headroom, the signal, and the fixed next-wake cadence.
	gc=""; case "$pace_signal" in GREEN) gc="$grn" ;; YELLOW) gc="$ylw" ;; RED) gc="$redc" ;; esac
	cap_note=""; ((pace_capped)) && cap_note=" ${dim}(capped)${rst}"
	burn_note=""; [ -n "$pace_hint" ] && burn_note="  ${bold}MONDAY-BURN${rst} ${dim}target ~99% by Tue 07:00${rst}"
	printf '  %-11s used %s%% · alloc %s%%%s %s(%d×15%% days + %d×1%% nights)%s · left %s%% · %s%s%s · next pass ~%s   %s(Michigan %s)%s%s\n' \
		"Pacing:" "$pace_used" "$pace_alloc" "$cap_note" "$dim" "$pace_days" "$pace_nights" "$rst" "$pace_left" \
		"$gc" "$pace_signal" "$rst" "$(human_until "$pace_sleep")" "$dim" "$pace_mday" "$rst" "$burn_note"
fi
signals_line
codex_line
if [ -n "$cost_today" ]; then
	# ccusage merges every agent CLI's own logs (claude + codex here — verified:
	# .daily[].agent == "all", one entry per date, so no double-counting) and
	# prices tokens at public API list rates: an equivalent-cost ESTIMATE on a
	# subscription plan, not a bill.
	echo "  Spend today (ccusage):       \$$cost_today ${dim}(claude + codex · API-rate est.)${rst}"
	# Last 7 days from the same cache: "Wed 53 · Thu 362 · …" with the median —
	# the honest eyeball for whether today is a burst or the new normal.
	days_line="$(sed -n 's/^DAYS=//p' "$CCUSAGE_CACHE" 2>/dev/null)"
	if [ -n "$days_line" ]; then
		hist="" meds=""
		for pair in $days_line; do
			d="${pair%%:*}"; v="${pair##*:}"
			dow="$(date -d "$d" +%a 2>/dev/null || printf '%s' "${d#*-}")"
			[ -n "$hist" ] && hist+=" ${dim}·${rst} "
			hist+="${dim}${dow}${rst} \$$v"
			meds+="$v "
		done
		med="$(printf '%s\n' $meds | sort -n | awk '{a[NR]=$1} END{if(NR)printf "%d", (NR%2)?a[(NR+1)/2]:(a[NR/2]+a[NR/2+1])/2}')"
		echo "  Last 7 days:                 $hist ${dim}(median \$$med/day)${rst}"
	fi
else
	echo "  ${dim}Spend today: ccusage unavailable${rst}"
fi
echo

if ((${#rows[@]} == 0)); then
	echo "  ${dim}No session caches yet ($CACHE_DIR/usage.*).${rst}"
	echo "  ${dim}Each session writes one after it renders post-API-call with the harvester wired.${rst}"
	exit 0
fi

# Compact token count: 638718 -> "639k".
fmt_k() { [ -n "${1:-}" ] && { (("$1" >= 1000)) && printf '%dk' $((($1 + 500) / 1000)) || printf '%s' "$1"; } || true; }

printf "  ${dim}%-16s %-12s %6s %6s %6s %7s %6s %5s %5s %7s${rst}\n" \
	"session" "model" "tok" "cache" "warm" "send\$" "ctx" "5h" "7d" "age"
# Sort rows by 7d desc (hottest first); empty 7d sorts last.
for r in "${rows[@]}"; do
	IFS='|' read -r label model ctx five seven age tok cache sendcost lastturn <<<"$r"
	printf '%s\t%s\n' "${seven:-0}" "$r"
done | sort -rn -k1 | cut -f2- | while IFS='|' read -r label model ctx five seven age tok cache sendcost lastturn; do
	c="$(round "$ctx")"; f="$(round "$five")"; s="$(round "$seven")"
	tk="$(fmt_k "$tok")"
	# Cache: green warm / yellow <50 / red <20 (low cache = expensive), matching
	# the per-session footer in ~/bin/claude-status.
	ch=""; ccol=""
	if [ -n "$cache" ]; then
		ch="$cache%"
		((cache < 50)) && ccol="$ylw"; ((cache < 20)) && ccol="$redc"
	fi
	# Cache-freshness countdown: this view refreshes reliably (on-demand + tmux
	# 60s), so a live "Nm" remaining-warm is honest here (unlike the per-pane
	# footer). green warm / red cold past the 300s TTL.
	wm="—"; wcol=""
	if [[ "$lastturn" =~ ^[0-9]+$ ]]; then
		remain=$((CACHE_TTL_SECONDS - (now - lastturn)))
		if ((remain > 0)); then wm="$(human_until "$remain")"; wcol="$grn"; else wm="cold"; wcol="$redc"; fi
	fi
	sc=""; [ -n "$sendcost" ] && sc="~\$$sendcost"
	agestr="$(human_until "$age") ago"
	printf "  %-16s %-12s %6s ${ccol}%6s${rst} ${wcol}%6s${rst} %7s %6s %5s %5s %7s\n" \
		"$label" "${model:-?}" "${tk:-—}" "${ch:-—}" "$wm" "${sc:-—}" "${c:+$c%}" "${f:+$f%}" "${s:+$s%}" "$agestr"
done

#!/usr/bin/env bash
#
# operate-context — single-session /clear SIZE verdict (KEEP/CLEAR).
#
# Answers one honest question at the end of a pass: is this session's context big
# enough that a reset is worth doing? It reads the last completed turn's context
# length from THIS session's transcript and compares it to a threshold derived from
# the model's context WINDOW. Above the threshold → CLEAR; below → KEEP.
#
# It deliberately does NOT weigh cache warmth or per-send cost. A warmth check run
# from INSIDE a live turn always reads "warm" (it sees its own just-now transcript
# timestamp), so a cost verdict is structurally pinned to KEEP — the bug this rewrite
# removes. WARMTH is a SAFETY concern, not a worth concern, and it is measured where
# it is honest: by the supervisor's idle-clear checker at clear time (clear only once
# the session has been idle past the ~5-min cache TTL, so the cache is already dead
# and the reset is free). See docs/designs/2026-07-02-consent-based-idle-clear.md.
#
# THE THRESHOLD: clear_ratio × window_tokens (default 0.75 × 200000 = 150000). The
# window is inferred from the model name — 1,000,000 for a `[1m]`/`-1m` model, else
# 200,000. Both the ratio and an explicit window are operate.json-overridable
# (context.clear_ratio, context.window_tokens) — holdco pins window_tokens to its 1M
# promo window there.
#
# USAGE:
#   operate context                 verdict for THIS repo's session ($PWD)
#   operate context --dir <path>    verdict for another repo's session (supervisor/testing)
#   operate context --session <id>  verdict for a specific transcript id (testing)
#
# Output: a short human block, then a final parseable line whose first field is the
# verdict, e.g.
#   KEEP  ctx=128k limit=150k window=200k model=opus
#   CLEAR ctx=180k limit=150k window=200k model=opus
#
# Deps: bash + jq. CLAUDE_PROJECTS_DIR is a test seam.

set -uo pipefail
export LC_ALL=C

JQ="$(command -v jq 2>/dev/null || true)"
CONFIG="${OPERATE_CONFIG:-$(cd "$(dirname "$0")/.." 2>/dev/null && pwd)/operate.json}"
cfg() { [ -n "$JQ" ] && [ -f "$CONFIG" ] && "$JQ" -r ".$1 // empty" "$CONFIG" 2>/dev/null || true; }
untilde() { case "$1" in "~/"*) printf '%s' "$HOME/${1#\~/}" ;; *) printf '%s' "$1" ;; esac; }

PROJECTS_DIR="${CLAUDE_PROJECTS_DIR:-}"
[ -n "$PROJECTS_DIR" ] || PROJECTS_DIR="$(untilde "$(cfg context.projects_dir)")"
[ -n "$PROJECTS_DIR" ] || PROJECTS_DIR="$HOME/.claude/projects"
RATIO="$(cfg context.clear_ratio)"; [ -n "$RATIO" ] || RATIO=0.75
WINDOW_OVERRIDE="$(cfg context.window_tokens)"

# The operator's cwd IS its repo root — resolve the session straight from $PWD
# (no caller-cwd forwarding hack; this tool lives in the repo it reports on).
dir="$PWD"
session=""
while [ $# -gt 0 ]; do
	case "$1" in
	--dir) shift; dir="${1:-}" ;;
	--session) shift; session="${1:-}" ;;
	-h | --help) awk 'NR==1{next} /^#/{sub(/^# ?/,"");print;next}{exit}' "$0"; exit 0 ;;
	*) echo "operate-context: unknown arg '$1'" >&2; exit 2 ;;
	esac
	shift
done

[ -n "$JQ" ] || { echo "operate-context: jq required" >&2; echo "UNKNOWN"; exit 0; }

# ---- resolve THIS session's transcript --------------------------------------
# Transcripts live at ~/.claude/projects/<munged-cwd>/<session>.jsonl, where the
# cwd is munged by replacing every non-alphanumeric char with '-'. For a cwd we
# take the most-recently-modified transcript in that dir (the live session).
transcript=""
if [ -n "$session" ]; then
	for f in "$PROJECTS_DIR"/*/"$session".jsonl; do [ -f "$f" ] && { transcript="$f"; break; }; done
else
	munged="$(printf '%s' "$dir" | sed 's/[^a-zA-Z0-9]/-/g')"
	tdir="$PROJECTS_DIR/$munged"
	[ -d "$tdir" ] && transcript="$(ls -t "$tdir"/*.jsonl 2>/dev/null | head -1)"
fi

if [ -z "$transcript" ] || [ ! -f "$transcript" ]; then
	echo "operate-context: no transcript for ${session:-$dir} (looked under $PROJECTS_DIR)" >&2
	echo "UNKNOWN"
	exit 0
fi

# ---- parse the transcript ---------------------------------------------------
# Every assistant turn's .message.usage carries input / cache_read /
# cache_creation token counts; their sum is the tokens fed to the model. The LAST
# such turn = the live context size; its model names the context window.
usage_jq='select(.type=="assistant" and (.isSidechain|not) and (.message.usage!=null))
	| (.message.model // "") as $m | .message.usage
	| ((.input_tokens // 0) + (.cache_read_input_tokens // 0) + (.cache_creation_input_tokens // 0)) as $tot
	| select($tot > 0)
	| "\($tot) \($m)"'

last_line="$(tail -n 400 "$transcript" 2>/dev/null | tac | "$JQ" -rc "$usage_jq" 2>/dev/null | head -1)"

bold=""; dim=""; rst=""; grn=""; ylw=""
if [ -t 1 ]; then bold=$'\e[1m'; dim=$'\e[2m'; rst=$'\e[0m'; grn=$'\e[32m'; ylw=$'\e[33m'; fi
fmt_k() { awk -v n="$1" 'BEGIN { printf (n >= 1000) ? "%dk" : "%d", (n >= 1000) ? (n + 500) / 1000 : n }'; }

ctx=0; model=""
[ -n "${last_line:-}" ] && read -r ctx model <<<"$last_line"
[[ "$ctx" =~ ^[0-9]+$ ]] || ctx=0

# Context window from the model name (1M for a [1m]/-1m promo model, else 200k),
# unless operate.json pins context.window_tokens.
window="$WINDOW_OVERRIDE"
if ! [[ "$window" =~ ^[0-9]+$ ]]; then
	case "$(printf '%s' "$model" | tr '[:upper:]' '[:lower:]')" in
	*1m*) window=1000000 ;;
	*)    window=200000 ;;
	esac
fi
limit="$(awk -v w="$window" -v r="$RATIO" 'BEGIN { printf "%d", w * r }')"
mtag="$(printf '%s' "$model" | sed 's/^claude-//; s/-[0-9].*//')"; mtag="${mtag:-unknown}"

verdict="KEEP"; (( ctx >= limit )) && verdict="CLEAR"
vcolor="$grn"; [ "$verdict" = "CLEAR" ] && vcolor="$ylw"
cmp="<"; [ "$verdict" = "CLEAR" ] && cmp="≥"

# ---- human-readable block ---------------------------------------------------
echo "${bold}operate context${rst}  ${dim}$dir${rst}"
if (( ctx == 0 )); then
	echo "  ${dim}no completed turn yet — fresh session, nothing to shed${rst}"
else
	echo "  context length    $(fmt_k "$ctx") tokens   ${dim}model $mtag, ${window} window${rst}"
fi
echo "  verdict           ${vcolor}${verdict}${rst}   ${dim}$(fmt_k "$ctx") ${cmp} $(fmt_k "$limit") clear-threshold (${RATIO}× window)${rst}"
echo

# ---- final parseable line (first field = verdict) ---------------------------
printf '%s ctx=%s limit=%s window=%s model=%s\n' \
	"$verdict" "$(fmt_k "$ctx")" "$(fmt_k "$limit")" "$window" "$mtag"

#!/usr/bin/env bash
#
# operate-self-clear — declare a clean-boundary READY-MARKER for the supervisor's
# idle-clear checker. (Formerly it queued `/clear` straight to this pane.)
#
# WHY A MARKER, NOT A DIRECT /clear: a session can't safely /clear ITSELF at the
# boundary — the pane may be mid-turn, the tree dirty, the context not worth clearing,
# or the owner mid-compose in the input box (a /clear would just append to the draft).
# So we DECLARE readiness here and let holdco's supervisor cron (`bin/holdco-idle-clear`)
# fire the clear once the pass has settled. (Clearing while the cache is warm is FINE:
# the static preamble is a persistent server-side cached prefix that survives /clear, so
# a warm clear preserves it rather than wasting it.) See
# docs/designs/2026-07-02-consent-based-idle-clear.md.
#
# WHAT IT DOES: writes a marker file (SESSION, CWD, PANE, TS, CTX_TOKENS) into the
# shared marker dir (default ~/.cache/operate-idle-clear, keyed by session id). The
# supervisor reads it, and — only once the pass has settled (turn done, pane at rest),
# its context is worth clearing (size gate), the tree is clean, and the input box is
# empty (an unsent draft would be clobbered) — sends the `/clear`. Deferring is always free.
#
# Declaring is UNCONDITIONAL at a clean boundary: judging whether the clear is
# worthwhile (size) and safe (idle, pane at rest, human-in-the-pane) is the
# supervisor's job now, not this session's. The one precondition enforced here is the
# clean boundary itself — a dirty working tree (excluding volatile channel-rewritten
# paths like data/mail) is NOT a boundary, so we decline (no marker) unless --force.
# `/clear` never touches the working tree, so leaving volatile mail uncommitted is safe.
#
# 🚨 Call this as the FINAL action of a pass, AFTER your work is committed and the
# pass is logged to git (WORKLOG.md), then stop. Write your `.operate/wake-brief.md`
# note-to-self first (a SessionStart hook re-injects it after the clear).
#
# USAGE: operate self-clear [--force]
#   (--if-optimal / --if-bloated [N] are accepted as deprecated no-op aliases so an
#    un-migrated persona keeps declaring correctly after `operate sync` pulls this.)
set -euo pipefail

SELF_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SELF_DIR/.."

JQ="$(command -v jq 2>/dev/null || true)"
CONFIG="${OPERATE_CONFIG:-$SELF_DIR/../operate.json}"
cfg() { [ -n "$JQ" ] && [ -f "$CONFIG" ] && "$JQ" -r ".$1 // empty" "$CONFIG" 2>/dev/null || true; }
untilde() { case "$1" in "~/"*) printf '%s' "$HOME/${1#\~/}" ;; *) printf '%s' "$1" ;; esac; }

CACHE_DIR="${CACHE_DIR:-}"
[ -n "$CACHE_DIR" ] || CACHE_DIR="$(untilde "$(cfg tokens.usage_dir)")"
[ -n "$CACHE_DIR" ] || CACHE_DIR="$HOME/.cache/claude-usage"

PROJECTS_DIR="${CLAUDE_PROJECTS_DIR:-}"
[ -n "$PROJECTS_DIR" ] || PROJECTS_DIR="$(untilde "$(cfg context.projects_dir)")"
[ -n "$PROJECTS_DIR" ] || PROJECTS_DIR="$HOME/.claude/projects"

MARKER_DIR="${OPERATE_MARKER_DIR:-}"
[ -n "$MARKER_DIR" ] || MARKER_DIR="$(untilde "$(cfg self_clear.marker_dir)")"
[ -n "$MARKER_DIR" ] || MARKER_DIR="$HOME/.cache/operate-idle-clear"

force=0
for a in "$@"; do
	case "$a" in
	--force) force=1 ;;
	--if-optimal | --if-bloated) ;;                # deprecated aliases — declaring is now unconditional
	[0-9]*) ;;                                      # deprecated --if-bloated threshold arg
	-h | --help) awk 'NR==1{next} /^#/{sub(/^# ?/,"");print;next}{exit}' "$0"; exit 0 ;;
	*) echo "self-clear: unknown arg '$a'" >&2; exit 2 ;;
	esac
done

# THIS session's own CTX_TOKENS (informational for the marker) from the usage cache:
# one KEY=VALUE file per session (statusline-written) whose CWD= equals this repo root.
ctx=""
shopt -s nullglob
for f in "$CACHE_DIR"/usage.*; do
	[[ "$(sed -n 's/^CWD=//p' "$f" | head -1)" == "$PWD" ]] || continue
	ctx="$(sed -n 's/^CTX_TOKENS=//p' "$f" | head -1)"
	break
done

# THIS session's id = the basename of its most-recent transcript for this cwd.
session=""
munged="$(printf '%s' "$PWD" | sed 's/[^a-zA-Z0-9]/-/g')"
tdir="$PROJECTS_DIR/$munged"
[ -d "$tdir" ] && { latest="$(ls -t "$tdir"/*.jsonl 2>/dev/null | head -1)"; [ -n "$latest" ] && session="$(basename "$latest" .jsonl)"; }

# Clean-boundary guard: a dirty tree (volatile channel-rewritten mail excluded — a
# native git pathspec, robust vs. line parsing) is NOT a boundary; decline.
if [[ "$force" != 1 ]] && [ -n "$(git status --porcelain -- . ':(exclude)data/mail' 2>/dev/null)" ]; then
	echo "self-clear: working tree is DIRTY — commit + log your pass first (or --force); not declared."
	exit 0
fi

# The supervisor clears by pane id, so a marker without one is useless — no-op.
if [[ -z "${TMUX_PANE:-}" ]]; then
	echo "self-clear: not inside a tmux pane (no \$TMUX_PANE) — nothing for the supervisor to clear; skipped."
	exit 0
fi

mkdir -p "$MARKER_DIR"
key="${session:-$munged}"
{
	printf 'SESSION=%s\n' "$session"
	printf 'CWD=%s\n' "$PWD"
	printf 'PANE=%s\n' "$TMUX_PANE"
	printf 'TS=%s\n' "$(date +%s)"
	printf 'CTX_TOKENS=%s\n' "$ctx"
} >"$MARKER_DIR/$key.marker"

echo "self-clear: declared ready-marker (${ctx:-?} ctx, pane $TMUX_PANE) — supervisor clears once the pass settles (pane at rest, input box empty). Stop now."

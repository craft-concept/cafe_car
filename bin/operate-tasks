#!/usr/bin/env -S deno run -A
// operate-tasks — file/list/update tasks on the holdco-tasks board.
// Self-contained so ventures can vendor it without the holdco repo.

/** @typedef {Record<string, unknown>} Row */

// Fatal boundary: a thrown die() → clean stderr + exit 1.
addEventListener('unhandledrejection', e => {
  e.preventDefault()
  console.error(e.reason instanceof Error ? e.reason.message : String(e.reason))
  Deno.exit(1)
})

let dir = decodeURIComponent(new URL('.', import.meta.url).pathname).replace(/\/$/, '')
let repo = dir + '/..'
let configFile = Deno.env.get('OPERATE_CONFIG') || repo + '/operate.json'
let envFile = Deno.env.get('OPERATE_ENV_FILE') || repo + '/.env'
let text = new TextDecoder()

let die = (msg: string): never => {
  throw new Error('operate tasks: ' + msg)
}

/** @param {string} file */
let read = async (file: string): Promise<string> => {
  try {
    return await Deno.readTextFile(file)
  } catch (err) {
    if (err instanceof Deno.errors.NotFound) return ''
    throw err
  }
}

/** @param {string} key */
let envval = async (key: string): Promise<string> => {
  let value = Deno.env.get(key)
  if (value) return value
  let line = (await read(envFile)).split('\n').find(x => x.startsWith(key + '='))
  if (!line) return ''
  value = line.slice(key.length + 1).replace(/\r$/, '')
  return /^".*"$/.test(value) ? value.slice(1, -1) : value
}

/** @param {string} key */
let cfg = async (key: string): Promise<string> => {
  let source = await read(configFile)
  if (!source) return ''
  try {
    let value = /** @type {Row} */ (JSON.parse(source))[key]
    return value == null ? '' : String(value)
  } catch (_) {
    return ''
  }
}

let url = (await envval('TASKS_WORKER_URL') || 'https://holdco-tasks.yaks.workers.dev').replace(/\/$/, '')
let token = await envval('TASKS_AGENT_TOKEN')
let venture = await cfg('venture') || await envval('TASKS_VENTURE_ID')

let needAuth = () => {
  if (!token) die(`no TASKS_AGENT_TOKEN in ${envFile} — the board requires auth.`)
  if (!venture) die("no venture id (operate.json 'venture' or TASKS_VENTURE_ID in .env).")
}

/** @param {unknown} value */
let str = (value: unknown): string => value == null ? '' : String(value)
/** @param {unknown} value @param {string} fallback */
let fallback = (value: unknown, fallback: string): string => value === null || value === undefined || value === false ? fallback : String(value)
/** @param {unknown} value */
let obj = (value: unknown): Record<string, unknown> => value && typeof value === 'object' ? value as Record<string, unknown> : {}
/** @param {unknown} value */
let ary = (value: unknown): unknown[] => Array.isArray(value) ? value : []

/** @param {string} body */
let errorBody = (body: string): string => {
  try {
    let value = /** @type {Row} */ (JSON.parse(body))
    return str(value.error ?? value.detail ?? body)
  } catch (_) {
    return body
  }
}

/** @param {string} path @param {RequestInit} [init] @param {string[]} [filters] */
let req = async (path: string, init: RequestInit = {}, filters: string[] = []): Promise<string> => {
  let target = new URL(url + path)
  for (let filter of filters) {
    let i = filter.indexOf('=')
    if (i < 0) target.search += (target.search ? '&' : '?') + encodeURIComponent(filter)
    else target.searchParams.append(filter.slice(0, i), filter.slice(i + 1))
  }
  /** @type {Response | undefined} */
  let res
  try {
    for (let i = 0; ; i += 1) {
      try {
        res = await fetch(target, { ...init, headers: { Authorization: `Bearer ${token}`, 'Content-Type': 'application/json', Accept: 'application/json', ...init.headers } })
        break
      } catch (err) {
        if (i == 2) throw err
      }
    }
  } catch (_) {
    die('board unreachable (curl exit 1) — note the item in WORKLOG and retry next pass.')
  }
  if (!res) die('board unreachable (curl exit 1) — note the item in WORKLOG and retry next pass.')
  let response = res as Response
  let body = await response.text()
  if (response.status >= 400) {
    console.error(`operate tasks: board rejected the request (HTTP ${response.status}):`)
    console.error(errorBody(body))
    die('fix the above and retry, or note it in WORKLOG.')
  }
  return body
}

/** @param {string} id */
let eid = (id: string): string => encodeURIComponent(id)
/** @param {string[]} pairs */
let jsonObj = (pairs: string[]): string => {
  /** @type {Record<string, string>} */
  let value: Record<string, string> = {}
  for (let i = 0; i < pairs.length; i += 2) if (pairs[i + 1]) value[pairs[i]] = pairs[i + 1]
  return JSON.stringify(value)
}

/** @param {string} id */
let ackPost = async (id: string): Promise<void> => {
  try {
    let res = await fetch(`${url}/api/v1/comments/${id}/ack`, { method: 'POST', headers: { Authorization: `Bearer ${token}`, 'Content-Type': 'application/json' } })
    if (!res.ok) console.error(`operate tasks: warn: ack of comment ${id} failed (non-fatal)`)
  } catch (_) {
    console.error(`operate tasks: warn: ack of comment ${id} failed (non-fatal)`)
  }
}

/** @param {string} id */
let autoAck = async (id: string): Promise<void> => {
  try {
    let res = await fetch(`${url}/api/v1/tasks/${id}/comments`, { headers: { Authorization: `Bearer ${token}`, Accept: 'application/json' } })
    let comments = ary(JSON.parse(await res.text()))
    for (let value of comments) {
      let comment = obj(value)
      if (comment.author != venture && comment.delivered_at != null && comment.acknowledged_at == null) await ackPost(str(comment.id))
    }
  } catch (_) {}
}

/** @param {string} body */
let rows = (body: string): Record<string, unknown>[] => ary(JSON.parse(body)).map(obj)
/** @param {Row} task */
let taskId = (task: Record<string, unknown>): string => fallback(task.slug ?? task.id, '')
/** @param {Row} task */
let renderListRow = (task: Record<string, unknown>): string => {
  let blockers = Number(task.open_blockers ?? 0) > 0 ? ` ⛔${task.open_blockers}` : ''
  let domain = task.domain ? `  [${task.domain}]` : ''
  let assignee = fallback(task.assignee, '')
  let who = assignee ? `→${assignee} ` : ''
  return `  ${fallback(task.priority, 'P2')}  ${str(task.title)}${domain}  ${str(task.status)}${blockers}  ${who}${fallback(task.venture_title ?? task.venture_id, '—')}  ${taskId(task)}`
}

/** @param {string} body */
let renderList = (body: string): void => {
  let tasks = rows(body)
  if (!tasks.length) console.log('  no tasks.')
  else for (let task of tasks) console.log(renderListRow(task))
}

/** @param {string[]} filters */
let list = async (filters: string[]): Promise<void> => {
  needAuth()
  renderList(await req('/api/v1/tasks', {}, filters))
}

let defaultList = async (): Promise<void> => {
  needAuth()
  renderList(await req('/api/v1/tasks', {}, [`.venture=${venture}`, '.status=open,wip,blocked', '.open_blockers=0']))
}

/** @param {string[]} args */
let file = async (args: string[]): Promise<void> => {
  needAuth()
  let title = '', desc = '', priority = '', kind = '', assign = '', target = venture, blockedBy = ''
  while (args.length) {
    let arg = args.shift() || ''
    if (arg == '--desc') desc = args.shift() || ''
    else if (arg == '--priority') priority = args.shift() || ''
    else if (arg == '--kind') kind = args.shift() || ''
    else if (arg == '--assign') assign = args.shift() || ''
    else if (arg == '--venture') target = args.shift() || ''
    else if (arg == '--blocked-by') blockedBy = args.shift() || ''
    else if (arg.startsWith('-')) die(`file: unknown flag '${arg}'`)
    else if (!title) title = arg
    else die(`file: unexpected arg '${arg}' (quote the title)`)
  }
  if (!title) die('file: a title is required — operate tasks file "Title" [--desc …]')
  let created = obj(JSON.parse(await req('/api/v1/tasks', { method: 'POST', body: jsonObj(['title', title, 'venture_id', target, 'actor', venture, 'description', desc, 'priority', priority, 'kind', kind, 'assignee', assign]) })))
  let id = taskId(created)
  console.log(`  created ${id}`)
  if (blockedBy) {
    await req(`/api/v1/tasks/${eid(id)}`, { method: 'PATCH', body: JSON.stringify({ addBlockedBy: [blockedBy], actor: venture }) })
    console.log(`  ⛔ blocked by ${blockedBy}`)
  }
}

/** @param {Row} task */
let depRow = (task: Record<string, unknown>): string => `  ${taskId(task)} · ${str(task.status)} · ${str(task.title)}`
/** @param {string} value */
let day = (value: string): string => value.slice(0, 10)

/** @param {string[]} args */
let show = async (args: string[]): Promise<void> => {
  needAuth()
  let id = args[0]
  if (!id) die('show: need a task id')
  let escaped = eid(id!)
  let task = obj(JSON.parse(await req(`/api/v1/tasks/${escaped}`)))
  let assignee = task.assignee !== null && task.assignee !== false && task.assignee !== undefined ? ` · →${str(task.assignee)}` : ''
  let domain = task.domain ? ` · [${task.domain}]` : ''
  /** @type {string[]} */
  let out = [`  ${taskId(task)}   ${fallback(task.priority, 'P2')} · ${str(task.status)} · ${fallback(task.kind, 'task')}${assignee}${domain}`, `  ${str(task.title)}`]
  if (task.venture_id) out.push(`  venture: ${fallback(task.venture_title ?? task.venture_id, '')}`)
  if (fallback(task.description, '')) out.push('\n' + str(task.description))
  let blockedBy = ary(task.blockedBy).map(obj)
  if (blockedBy.length) out.push('\n  -- blocked by --', ...blockedBy.map(depRow))
  let blocks = ary(task.blocks).map(obj)
  if (blocks.length) out.push('\n  -- blocks --', ...blocks.map(depRow))
  console.log(out.join('\n'))
  let comments = rows(await req(`/api/v1/tasks/${escaped}/comments`))
  if (comments.length) {
    console.log('\n  -- thread --')
    for (let comment of comments) console.log(`  ${str(comment.id)} · ${day(str(comment.created_at))} · ${str(comment.author)}: ${str(comment.body)}`)
  }
  await autoAck(escaped)
}

/** @param {string} verb @param {string} status @param {string[]} args */
let patchStatus = async (verb: string, status: string, args: string[]): Promise<void> => {
  needAuth()
  let id = args.shift()
  if (!id) die(`${verb}: need a task id`)
  let reason = ''
  while (args.length) {
    let arg = args.shift()
    if (arg == '--reason') reason = args.shift() || ''
    else die(`${verb}: unexpected arg '${arg}'`)
  }
  let escaped = eid(id!)
  let task = obj(JSON.parse(await req(`/api/v1/tasks/${escaped}`, { method: 'PATCH', body: jsonObj(['status', status, 'actor', venture, 'reason', reason]) })))
  console.log(`  ✓ ${taskId(task)} → ${str(task.status)}`)
  if (verb == 'claim' || verb == 'done') await autoAck(escaped)
}

/** @param {string[]} args */
let update = async (args: string[]): Promise<void> => {
  needAuth()
  let id = args.shift()
  if (!id) die('update: need a task id')
  let reason = '', pairs = []
  while (args.length) {
    let arg = args.shift() || ''
    if (arg == '--reason') reason = args.shift() || ''
    else if (arg.includes('=')) { let i = arg.indexOf('='); pairs.push(arg.slice(0, i), arg.slice(i + 1)) }
    else die(`update: expected field=value (or --reason), got '${arg}'`)
  }
  if (!pairs.length) die('update: need at least one field=value (e.g. priority=P1)')
  let task = obj(JSON.parse(await req(`/api/v1/tasks/${eid(id!)}`, { method: 'PATCH', body: jsonObj([...pairs, 'actor', venture, 'reason', reason]) })))
  console.log(`  ✓ ${taskId(task)} updated`)
  await autoAck(eid(id!))
}

/** @param {string[]} args */
let commentRm = async (args: string[]): Promise<void> => {
  needAuth()
  let id = args.shift()
  if (!id) die('comment rm: need a comment id')
  let reason = ''
  while (args.length) {
    let arg = args.shift()
    if (arg == '--reason') reason = args.shift() || ''
    else die(`comment rm: unexpected arg '${arg}'`)
  }
  await req(`/api/v1/comments/${eid(id!)}`, { method: 'DELETE', body: jsonObj(['actor', venture, 'reason', reason]) })
  console.log(`  ✗ deleted comment ${id}`)
}

/** @param {string[]} args */
let comment = async (args: string[]): Promise<void> => {
  if (args[0] == 'rm') return commentRm(args.slice(1))
  needAuth()
  let id = args[0], body = args[1]
  if (!id) die('comment: need a task id')
  if (!body) die('comment: need text — operate tasks comment <id> "…"')
  await req(`/api/v1/tasks/${eid(id)}/comments`, { method: 'POST', body: jsonObj(['author', venture, 'body', body]) })
  console.log(`  commented on ${id}`)
  await autoAck(eid(id))
}

/** @param {string[]} args */
let dep = async (args: string[]): Promise<void> => {
  needAuth()
  let remove = args[0] == 'rm'
  if (remove) args.shift()
  let id = args.shift()
  if (!id) die('dep: need a task id')
  let rel = '', other = ''
  while (args.length) {
    let arg = args.shift()
    if (arg == '--by') { rel = 'BlockedBy'; other = args.shift() || '' }
    else if (arg == '--blocks') { rel = 'Blocks'; other = args.shift() || '' }
    else die(`dep: unexpected arg '${arg}' — use --by <blocker> or --blocks <task>`)
  }
  if (!rel || !other) die('dep: need --by <blocker> or --blocks <task>')
  let field = `${remove ? 'remove' : 'add'}${rel}`
  await req(`/api/v1/tasks/${eid(id!)}`, { method: 'PATCH', body: JSON.stringify({ [field]: [other], actor: venture }) })
  let phrase = rel == 'BlockedBy' ? 'blocked by' : 'blocks'
  console.log(remove ? `  ✓ ${id} no longer ${phrase} ${other}` : `  ✓ ${id} ${phrase} ${other}`)
}

/** @param {string[]} args */
let ack = async (args: string[]): Promise<void> => {
  needAuth()
  let id = args[0]
  if (!id) die('ack: need a task id')
  let comments = rows(await req(`/api/v1/tasks/${eid(id)}/comments`))
  let count = 0
  for (let comment of comments) if (comment.author != venture && comment.acknowledged_at == null) { await ackPost(str(comment.id)); count += 1 }
  console.log(`  acked ${count} comment${count == 1 ? '' : 's'} on ${id}`)
}

let help = () => console.log(`operate-tasks — file/list/update tasks on the holdco-tasks board (the one system).

  operate tasks                       list MY open/wip/blocked tasks, priority order
  operate tasks list [.filters…]      raw dot-filter passthrough (no venture scope)
  operate tasks file "Title" [--desc "…"] [--priority P0|P1|P2]
                                      [--kind task|idea|bug|feedback|proposal|research|note]
                                      [--assign jeff] [--venture <id>] [--blocked-by <id>]  → POST, prints the id
  operate tasks show <id>             task + comment thread + deps
  operate tasks dep <id> --by <blocker>       link: <id> is blocked by <blocker>
  operate tasks dep <id> --blocks <other>     link: <id> blocks <other>
  operate tasks dep rm <id> --by/--blocks <other>   remove a dependency edge
  operate tasks claim <id>            status → wip
  operate tasks done <id> [--reason "…"]     status → done
  operate tasks cancel <id> [--reason "…"]   status → cancelled (deliberately abandoned)
  operate tasks update <id> field=value… [--reason "…"]
  operate tasks comment <id> "text"   post a comment (authored as this venture)
  operate tasks comment rm <comment-id> [--reason "…"]   soft-delete a comment (id from show)
  operate tasks ack <id>              mark the owner's changes on <id> seen (all non-self comments)`)

let args = [...Deno.args]
let sub = args[0]
if (!sub) await defaultList()
else if (['-h', '--help', 'help'].includes(sub)) help()
else if (sub == 'list') await list(args.slice(1))
else if (sub == 'file') await file(args.slice(1))
else if (sub == 'show') await show(args.slice(1))
else if (sub == 'claim') await patchStatus('claim', 'wip', args.slice(1))
else if (sub == 'done') await patchStatus('done', 'done', args.slice(1))
else if (sub == 'cancel') await patchStatus('cancel', 'cancelled', args.slice(1))
else if (sub == 'update') await update(args.slice(1))
else if (sub == 'comment') await comment(args.slice(1))
else if (sub == 'dep') await dep(args.slice(1))
else if (sub == 'ack') await ack(args.slice(1))
else if (sub.startsWith('.') || sub.includes('=')) await list(args)
else die(`unknown subcommand '${sub}' — run 'operate tasks --help'`)

#!/usr/bin/env bash
#
# operate-tasks — file/list/update tasks on the holdco-tasks board (the one system).
#
# The single client for the holdco-tasks D1 Worker, fleet-wide. Local git tasks/
# are retired; every operator files, lists, and closes tasks here. Standalone
# bash+curl+jq — no holdco repo on the box; config comes from this venture's own
# operate.json + .env (already provisioned in every repo).
#
#   operate tasks                       list MY open/wip/blocked tasks, priority order
#   operate tasks list [.filters…]      raw dot-filter passthrough (no venture scope)
#   operate tasks file "Title" [--desc "…"] [--priority P0|P1|P2]
#                                       [--kind task|idea|bug|feedback|proposal|research|note]
#                                       [--assign jeff] [--venture <id>] [--blocked-by <id>]  → POST, prints the id
#     tip: file ONE atomic task — a single verifiable outcome, not a checklist.
#          Multi-step work = several small linked tasks (use --blocked-by), not one fat task.
#   operate tasks show <id>             task + comment thread + timeline + deps
#   operate tasks dep <id> --by <blocker>       link: <id> is blocked by <blocker>
#   operate tasks dep <id> --blocks <other>     link: <id> blocks <other>
#   operate tasks dep rm <id> --by/--blocks <other>   remove a dependency edge
#   operate tasks claim <id>            status → wip
#   operate tasks done   <id> [--reason "…"]     status → done
#   operate tasks cancel <id> [--reason "…"]     status → cancelled (deliberately abandoned)
#   operate tasks update <id> field=value… [--reason "…"]
#                                       generic PATCH — triage IS update (priority=P1 domain=Eng),
#                                       reassignment IS update (assignee=jeff --reason "need keys")
#   operate tasks comment <id> "text"   post a comment (authored as this venture)
#   operate tasks ack <id>              mark the owner's changes on <id> seen (all non-self comments)
#
# A `--reason` is the commit-message "why": stored on the timeline and — when a
# field changed — dual-written as a thread comment, which bin/holdco deliver relays
# to the affected operator. Reassignment to `jeff` is how a task reaches the owner
# (blocked-on-user is retired: his queue is just `.assignee=jeff`).
#
# Acting on a task (show/claim/done/update/comment) auto-acks the owner comments
# already delivered to this operator's inbox — so the owner sees ✓✓ seen without
# a manual step; `ack <id>` is the explicit form. Ack is best-effort (never blocks
# the primary command).
#
# Config (all venture-local): venture id from operate.json `venture` (fallback
# TASKS_VENTURE_ID in .env); URL from TASKS_WORKER_URL (default workers.dev);
# token from TASKS_AGENT_TOKEN in .env — a missing token is a loud error.
#
# Failure mode: fail loudly, no offline queue. curl --retry 2 rides transient
# blips; a hard failure prints the server error verbatim (the dot-filter 400s
# teach the syntax) plus "note it in WORKLOG and retry next pass", exit non-zero.
#
# Deps: bash, curl, jq.

set -uo pipefail
export LC_ALL=C

DIR="$(cd "$(dirname "$0")" && pwd)"
REPO="$(cd "$DIR/.." && pwd)"
JQ="$(command -v jq 2>/dev/null || true)"
CONFIG="${OPERATE_CONFIG:-$REPO/operate.json}"
cfg() { [ -n "$JQ" ] && [ -f "$CONFIG" ] && "$JQ" -r ".$1 // empty" "$CONFIG" 2>/dev/null || true; }

die() { echo "operate tasks: $*" >&2; exit 1; }
[ -n "$JQ" ] || die "jq not found — install it (this tool builds/reads JSON with jq)."

# ---- config: read the venture's .env + operate.json --------------------------
# The .env triple (TASKS_WORKER_URL / TASKS_AGENT_TOKEN / TASKS_VENTURE_ID) already
# exists in every repo. Env already set wins (test seam); else read the file.
ENV_FILE="${OPERATE_ENV_FILE:-$REPO/.env}"
envval() { # <KEY> — value from the environment, else from .env (unquoted)
	local k="$1" v="${!1:-}"
	if [ -n "$v" ]; then printf '%s' "$v"; return; fi
	[ -f "$ENV_FILE" ] || return 0
	sed -n "s/^${k}=//p" "$ENV_FILE" 2>/dev/null | head -n1 | sed 's/^"\(.*\)"$/\1/'
}

URL="$(envval TASKS_WORKER_URL)"; [ -n "$URL" ] || URL="https://holdco-tasks.yaks.workers.dev"
URL="${URL%/}"
TOKEN="$(envval TASKS_AGENT_TOKEN)"
VENTURE="$(cfg venture)"; [ -n "$VENTURE" ] || VENTURE="$(envval TASKS_VENTURE_ID)"

need_auth() {
	[ -n "$TOKEN" ] || die "no TASKS_AGENT_TOKEN in $ENV_FILE — the board requires auth."
	[ -n "$VENTURE" ] || die "no venture id (operate.json 'venture' or TASKS_VENTURE_ID in $ENV_FILE)."
}

# ---- http core --------------------------------------------------------------
# All args are extra curl args; the last must be the URL. Prints the response
# body on success; on transport failure or HTTP >=400 prints the server error
# verbatim + doctrine and exits non-zero (no retry-queue — see header).
req() {
	local out code rc
	out="$(mktemp)"
	code="$(curl -sS --retry 2 --retry-connrefused \
		-o "$out" -w '%{http_code}' \
		-H "Authorization: Bearer $TOKEN" \
		-H "Content-Type: application/json" \
		-H "Accept: application/json" \
		"$@" 2>/dev/null)"
	rc=$?
	if [ "$rc" -ne 0 ]; then
		rm -f "$out"
		die "board unreachable (curl exit $rc) — note the item in WORKLOG and retry next pass."
	fi
	if [ "$code" -ge 400 ] 2>/dev/null; then
		echo "operate tasks: board rejected the request (HTTP $code):" >&2
		"$JQ" -r '.error // .detail // .' "$out" >&2 2>/dev/null || cat "$out" >&2
		rm -f "$out"
		die "fix the above and retry, or note it in WORKLOG."
	fi
	cat "$out"; rm -f "$out"
}

# Build a JSON object from key value pairs; pairs with an empty value are omitted.
# Everything is string-typed — the Worker's columns are all TEXT.
json_obj() {
	local jqargs=() filter='{}' k v i=0
	while [ $# -gt 0 ]; do
		k="$1"; v="${2:-}"; shift 2 || shift $#
		[ -n "$v" ] || continue
		jqargs+=(--arg "k$i" "$k" --arg "v$i" "$v")
		filter="$filter + {(\$k$i): \$v$i}"
		i=$((i + 1))
	done
	"$JQ" -n "${jqargs[@]}" "$filter"
}

# ---- acknowledge (layered "seen") -------------------------------------------
# When this operator acts on a task it has "seen" the owner's changes, so we
# stamp acknowledged_at on the task's non-self comments (POST /comments/:id/ack,
# idempotent). Best-effort throughout: a missing/failed ack must NEVER break the
# primary command — we warn and carry on, never `req` (which would exit on error).

# Best-effort ack of one comment id — warn-only on failure.
ack_post() { # <comment-id>
	curl -sS --retry 1 -o /dev/null \
		-H "Authorization: Bearer $TOKEN" \
		-H "Content-Type: application/json" \
		-X POST "$URL/api/v1/comments/$1/ack" 2>/dev/null \
		|| echo "operate tasks: warn: ack of comment $1 failed (non-fatal)" >&2
}

# Auto-ack after acting on a task: the comments delivered to this operator's inbox
# but not yet acked and NOT authored by it. Fully best-effort (own curl, not req).
auto_ack() { # <url-encoded task id>
	local eid="$1" comments ids cid
	comments="$(curl -sS --retry 1 \
		-H "Authorization: Bearer $TOKEN" -H "Accept: application/json" \
		"$URL/api/v1/tasks/$eid/comments" 2>/dev/null)" || return 0
	ids="$(printf '%s' "$comments" | "$JQ" -r --arg me "$VENTURE" \
		'.[]? | select(.author != $me and .delivered_at != null and .acknowledged_at == null) | .id' 2>/dev/null)" || return 0
	for cid in $ids; do ack_post "$cid"; done
}

# ---- rendering --------------------------------------------------------------
list_fmt='.[] | "  \(.priority // "P2")  \(.title)\(if .domain then "  [\(.domain)]" else "" end)  \(.status)\(if (.open_blockers // 0) > 0 then " ⛔\(.open_blockers)" else "" end)  \((.assignee // "") | if . == "" then "" else "→\(.) " end)\(.venture_title // .venture_id // "—")  \(.slug // .id)"'

render_list() {
	local json="$1"
	if [ "$(printf '%s' "$json" | "$JQ" -r 'length')" = 0 ]; then
		echo "  no tasks."; return
	fi
	printf '%s' "$json" | "$JQ" -r "$list_fmt"
}

# ---- commands ---------------------------------------------------------------

cmd_list() { # [.filters…]  (RAW passthrough — no venture scope injected)
	need_auth
	local dataurl=() f
	for f in "$@"; do dataurl+=(--data-urlencode "$f"); done
	render_list "$(req -G "${dataurl[@]}" "$URL/api/v1/tasks")"
}

cmd_default() { # bare `operate tasks` — MY ready open/wip/blocked, priority order
	need_auth
	# .open_blockers=0 drops tasks with ≥1 OPEN blocker (D2): a blocked task isn't
	# ready, so it leaves the queue until its blockers close. See `list` for all.
	render_list "$(req -G \
		--data-urlencode ".venture=$VENTURE" \
		--data-urlencode ".status=open,wip,blocked" \
		--data-urlencode ".open_blockers=0" \
		"$URL/api/v1/tasks")"
}

cmd_file() {
	need_auth
	local title="" desc="" priority="" kind="" assign="" venture="$VENTURE" blocked_by=""
	while [ $# -gt 0 ]; do
		case "$1" in
		--desc) desc="${2:-}"; shift 2 ;;
		--priority) priority="${2:-}"; shift 2 ;;
		--kind) kind="${2:-}"; shift 2 ;;
		--assign) assign="${2:-}"; shift 2 ;;
		--venture) venture="${2:-}"; shift 2 ;;
		--blocked-by) blocked_by="${2:-}"; shift 2 ;;
		-*) die "file: unknown flag '$1'" ;;
		*) [ -z "$title" ] && title="$1" || die "file: unexpected arg '$1' (quote the title)"; shift ;;
		esac
	done
	[ -n "$title" ] || die "file: a title is required — operate tasks file \"Title\" [--desc …]"
	local body id
	body="$(json_obj title "$title" venture_id "$venture" actor "$VENTURE" \
		description "$desc" priority "$priority" kind "$kind" assignee "$assign")"
	id="$(req -X POST --data-raw "$body" "$URL/api/v1/tasks" | "$JQ" -r '.slug // .id')"
	echo "  created $id"
	# Link the new task under a blocker in the same breath (the atomic-task path:
	# a step that waits on a prior one). PATCH addBlockedBy, keyed on the new slug.
	if [ -n "$blocked_by" ]; then
		local eid dep_body
		eid="$("$JQ" -rn --arg s "$id" '$s|@uri')"
		dep_body="$("$JQ" -n --arg o "$blocked_by" --arg a "$VENTURE" '{addBlockedBy:[$o], actor:$a}')"
		req -X PATCH --data-raw "$dep_body" "$URL/api/v1/tasks/$eid" >/dev/null
		echo "  ⛔ blocked by $blocked_by"
	fi
}

cmd_show() {
	need_auth
	local id="${1:-}"; [ -n "$id" ] || die "show: need a task id"
	local eid; eid="$("$JQ" -rn --arg s "$id" '$s|@uri')"
	local task; task="$(req "$URL/api/v1/tasks/$eid")"
	printf '%s' "$task" | "$JQ" -r '
		"  \(.slug // .id)   \(.priority // "P2") · \(.status) · \(.kind // "task")\(if .assignee then " · →\(.assignee)" else "" end)\(if .domain then " · [\(.domain)]" else "" end)",
		"  \(.title)",
		(if .venture_id then "  venture: \(.venture_title // .venture_id)" else empty end),
		(if (.description // "") != "" then "\n\(.description)" else empty end),
		(if (.blockedBy // [] | length) > 0 then "\n  -- blocked by --", (.blockedBy[] | "  \(.slug // .id) · \(.status) · \(.title)") else empty end),
		(if (.blocks // [] | length) > 0 then "\n  -- blocks --", (.blocks[] | "  \(.slug // .id) · \(.status) · \(.title)") else empty end)'
	local comments; comments="$(req "$URL/api/v1/tasks/$eid/comments")"
	if [ "$(printf '%s' "$comments" | "$JQ" -r 'length')" != 0 ]; then
		echo; echo "  -- thread --"
		printf '%s' "$comments" | "$JQ" -r '.[] | "  \(.created_at[0:10]) · \(.author): \(.body)"'
	fi
	local events; events="$(req "$URL/api/v1/tasks/$eid/events")"
	if [ "$(printf '%s' "$events" | "$JQ" -r 'length')" != 0 ]; then
		echo; echo "  -- history --"
		printf '%s' "$events" | "$JQ" -r '.[] |
			"  \(.created_at[0:10]) · \(.actor) · " +
			(if .field == "created" then "created" else "\(.field): \(.old // "∅") → \(.new // "∅")" end) +
			(if .reason then " — \(.reason)" else "" end)'
	fi
	auto_ack "$eid"
}

# Explicit acknowledge: mark every non-self comment on the task seen (not just the
# delivered-but-unacked set auto_ack handles). Idempotent server-side.
cmd_ack() {
	need_auth
	local id="${1:-}"; [ -n "$id" ] || die "ack: need a task id"
	local eid; eid="$("$JQ" -rn --arg s "$id" '$s|@uri')"
	local comments ids cid n=0
	comments="$(req "$URL/api/v1/tasks/$eid/comments")"
	ids="$(printf '%s' "$comments" | "$JQ" -r --arg me "$VENTURE" \
		'.[] | select(.author != $me and .acknowledged_at == null) | .id')"
	for cid in $ids; do ack_post "$cid"; n=$((n + 1)); done
	echo "  acked $n comment$([ "$n" = 1 ] || echo s) on $id"
}

# PATCH a task's status (claim/done/cancel) with an optional --reason.
patch_status() { # <verb> <new-status> <id> [--reason "…"]
	need_auth
	local verb="$1" status="$2"; shift 2
	local id="${1:-}"; [ -n "$id" ] || die "$verb: need a task id"; shift || true
	local reason=""
	while [ $# -gt 0 ]; do
		case "$1" in --reason) reason="${2:-}"; shift 2 ;; *) die "$verb: unexpected arg '$1'" ;; esac
	done
	local eid; eid="$("$JQ" -rn --arg s "$id" '$s|@uri')"
	local body; body="$(json_obj status "$status" actor "$VENTURE" reason "$reason")"
	req -X PATCH --data-raw "$body" "$URL/api/v1/tasks/$eid" \
		| "$JQ" -r '"  ✓ \(.slug // .id) → \(.status)"'
	# Acting on a task (claim/done) means the operator has seen the owner's changes.
	case "$verb" in claim | done) auto_ack "$eid" ;; esac
}

cmd_update() { # <id> field=value… [--reason "…"]
	need_auth
	local id="${1:-}"; [ -n "$id" ] || die "update: need a task id"; shift
	local reason="" pairs=() a k v
	while [ $# -gt 0 ]; do
		a="$1"; shift
		case "$a" in
		--reason) reason="${1:-}"; shift || true ;;
		*=*) k="${a%%=*}"; v="${a#*=}"; pairs+=("$k" "$v") ;;
		*) die "update: expected field=value (or --reason), got '$a'" ;;
		esac
	done
	[ "${#pairs[@]}" -gt 0 ] || die "update: need at least one field=value (e.g. priority=P1)"
	local eid; eid="$("$JQ" -rn --arg s "$id" '$s|@uri')"
	local body; body="$(json_obj "${pairs[@]}" actor "$VENTURE" reason "$reason")"
	req -X PATCH --data-raw "$body" "$URL/api/v1/tasks/$eid" \
		| "$JQ" -r '"  ✓ \(.slug // .id) updated"'
	auto_ack "$eid"
}

cmd_comment() {
	need_auth
	local id="${1:-}"; [ -n "$id" ] || die "comment: need a task id"
	local text="${2:-}"; [ -n "$text" ] || die "comment: need text — operate tasks comment <id> \"…\""
	local eid; eid="$("$JQ" -rn --arg s "$id" '$s|@uri')"
	local body; body="$(json_obj author "$VENTURE" body "$text")"
	req -X POST --data-raw "$body" "$URL/api/v1/tasks/$eid/comments" >/dev/null
	echo "  commented on $id"
	auto_ack "$eid"
}

# Add or remove a dependency edge (WS3). `dep <id> --by X` = <id> is blocked by X;
# `dep <id> --blocks Y` = <id> blocks Y. Prefix `rm` to remove. One PATCH to the
# addressed task with the matching add/remove array; the server rejects self-edges
# and cycles.
cmd_dep() {
	need_auth
	local remove=0
	if [ "${1:-}" = "rm" ]; then remove=1; shift; fi
	local id="${1:-}"; [ -n "$id" ] || die "dep: need a task id"; shift || true
	local rel="" other=""
	while [ $# -gt 0 ]; do
		case "$1" in
		--by) rel="BlockedBy"; other="${2:-}"; shift 2 ;;
		--blocks) rel="Blocks"; other="${2:-}"; shift 2 ;;
		*) die "dep: unexpected arg '$1' — use --by <blocker> or --blocks <task>" ;;
		esac
	done
	[ -n "$rel" ] && [ -n "$other" ] || die "dep: need --by <blocker> or --blocks <task>"
	local verb field eid body
	[ "$remove" = 1 ] && verb="remove" || verb="add"
	field="${verb}${rel}"   # addBlockedBy | removeBlockedBy | addBlocks | removeBlocks
	eid="$("$JQ" -rn --arg s "$id" '$s|@uri')"
	body="$("$JQ" -n --arg f "$field" --arg o "$other" --arg a "$VENTURE" '{($f):[$o], actor:$a}')"
	req -X PATCH --data-raw "$body" "$URL/api/v1/tasks/$eid" >/dev/null
	if [ "$remove" = 1 ]; then
		echo "  ✓ $id no longer $([ "$rel" = BlockedBy ] && echo "blocked by" || echo "blocks") $other"
	else
		echo "  ✓ $id $([ "$rel" = BlockedBy ] && echo "blocked by" || echo "blocks") $other"
	fi
}

help() { awk 'NR<=2{next} /^#/{sub(/^# ?/,"");print;next}{exit}' "$0"; }

# ---- dispatch ---------------------------------------------------------------
[ $# -gt 0 ] || { cmd_default; exit 0; }
sub="$1"
case "$sub" in
-h | --help | help) help ;;
list) shift; cmd_list "$@" ;;
file) shift; cmd_file "$@" ;;
show) shift; cmd_show "$@" ;;
claim) shift; patch_status claim wip "$@" ;;
done) shift; patch_status done done "$@" ;;
cancel) shift; patch_status cancel cancelled "$@" ;;
update) shift; cmd_update "$@" ;;
comment) shift; cmd_comment "$@" ;;
dep) shift; cmd_dep "$@" ;;
ack) shift; cmd_ack "$@" ;;
.* | *=*) cmd_list "$@" ;; # implicit list from a filter/control-param first arg
*) die "unknown subcommand '$sub' — run 'operate tasks --help'" ;;
esac
